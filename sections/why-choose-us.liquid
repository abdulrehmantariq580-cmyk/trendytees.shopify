{%- style -%}
  .why-choose-section {
    padding: 6rem 0;
    background-color: #cecfd1;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow-x: hidden;
  }

  .why-choose-container {
    max-width: 1200px;
    width: 90%;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4rem;
  }

  .why-choose-left {
    flex: 1 1 40%;
    min-width: 300px;
  }

  .why-choose-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 600;
    color: #111;
    margin-bottom: 1.5rem;
  }

  .why-choose-text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.8;
    color: #333;
    margin-bottom: 2.5rem;
  }

  .why-choose-btn {
    display: inline-block;
    padding: 0.8rem 2.5rem;
    background-color: #111;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 30px;
    transition: all 0.3s ease;
  }

  .why-choose-btn:hover {
    background-color: #333;
  }

  .why-choose-right {
    flex: 1 1 50%;
    min-width: 300px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .why-choose-card {
    background-color: #fff;
    padding: 2rem 1.5rem;
    border-radius: 12px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    text-align: center;
  }

  .why-choose-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 0.8rem;
  }

  .why-choose-card-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #666;
  }
  .why-choose-card-text p {
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .why-choose-section {
      width: 100vw;
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      padding: 4rem 0;
    }
    .why-choose-container {
      flex-direction: column;
      gap: 3rem;
      text-align: center;
    }
    .why-choose-right {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="why-choose-section" id="WhyChoose-{{ section.id }}">
  <div class="why-choose-container">
    <div class="why-choose-left">
      {%- if section.settings.title != blank -%}
        <h2 class="why-choose-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      
      {%- if section.settings.text != blank -%}
        <div class="why-choose-text">{{ section.settings.text }}</div>
      {%- endif -%}
      
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="why-choose-btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
    
    <div class="why-choose-right">
      {%- for block in section.blocks -%}
        <div class="why-choose-card" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h3 class="why-choose-card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="why-choose-card-text">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why Choose Trendy Tees?"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Premium quality, trusted service, and customer-first experience. Every order is crafted with attention to detail and delivered with confidence.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Direct Manufacturer"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>We manufacture directly, ensuring better quality and competitive pricing.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        { "type": "feature", "settings": { "title": "Direct Manufacturer", "text": "<p>We manufacture directly, ensuring better quality and competitive pricing.</p>" } },
        { "type": "feature", "settings": { "title": "Check Before Payment", "text": "<p>Inspect your order before making payment for complete peace of mind.</p>" } },
        { "type": "feature", "settings": { "title": "7 Days Exchange", "text": "<p>Easy exchange policy if the product does not meet your expectations.</p>" } },
        { "type": "feature", "settings": { "title": "Fast Delivery", "text": "<p>Quick and secure delivery across Pakistan.</p>" } }
      ]
    }
  ]
}
{% endschema %}
