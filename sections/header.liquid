<header class="site-header full-width">
  <div class="page-width site-header__inner">
    
    <div class="site-header__logo">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 250 }}"
               alt="{{ shop.name }}"
               loading="eager"
               width="{{ section.settings.logo.width }}"
               height="{{ section.settings.logo.height }}">
        {% else %}
          <span class="h2">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <nav class="site-header__menu">
      <ul class="site-header__menu-list">
        {% for link in section.settings.menu.links %}
          <li>
            <a href="{{ link.url }}" class="site-header__menu-link {% if link.active %}site-header__menu-link--active{% endif %}">
              {{ link.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="site-header__icons">
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="site-header__icon" aria-label="Account">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      {% endif %}

      <a href="{{ routes.cart_url }}" class="site-header__icon site-header__cart" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="site-header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
