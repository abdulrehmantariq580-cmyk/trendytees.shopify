<style>
  .site-header {
    background-color: #ffffff;
    color: #000000;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding: 1.5rem 0 0 0;
  }
  .site-header__top-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-bottom: 1rem;
    position: relative;
  }
  .site-header__icon {
    color: #000;
    text-decoration: none;
  }
  .site-header__icon:hover {
    color: #666;
  }
  .site-header__logo-container {
    text-align: center;
  }
  .site-header__icons-container {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.5rem;
  }
  .site-header__left-nav {
    display: flex;
    justify-content: flex-start;
    align-items: center;
  }
  .site-header__nav-row {
    display: flex;
    justify-content: center;
    padding: 1rem 0;
  }
  .site-header__nav-list {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 2rem;
  }
  .site-header__nav-item {
    font-size: 0.85rem;
    text-transform: uppercase;
    font-weight: 500;
    color: #666;
    text-decoration: none;
    letter-spacing: 1px;
    padding-bottom: 5px;
  }
  .site-header__nav-item:hover, .site-header__nav-item--active {
    color: #000;
    border-bottom: 2px solid #000;
  }
  .nav-item-dropdown:hover .dropdown-menu {
    display: block !important;
  }
  .site-header__cart-count {
    background-color: #000;
    color: #fff;
  }
  
  /* Mobile menu styles */
  .site-header__menu-toggle {
    display: none;
    color: #000;
    background: none;
    border: none;
    cursor: pointer;
  }
  @media screen and (max-width: 768px) {
    .site-header__nav-row {
      display: none;
    }
    .site-header__menu-toggle {
      display: block;
    }
  }
</style>

<header class="site-header full-width" style="position: relative;">
  <!-- Inline Search Container -->
  <div class="site-header__search-container" id="HeaderSearchContainer" style="display: none; position: absolute; top: 100%; left: 0; width: 100%; background: #fff; padding: 1rem; border-bottom: 1px solid #eee; z-index: 10; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
    <form action="{{ routes.search_url }}" method="get" class="search-form" style="display: flex; max-width: 600px; margin: 0 auto; gap: 10px;">
      <input type="text" name="q" placeholder="Search..." style="flex-grow: 1; padding: 10px; border: 1px solid #ccc;" />
      <button type="submit" style="background: #000; color: #fff; padding: 10px 20px; border: none; cursor: pointer;">Search</button>
    </form>
  </div>

  <div class="page-width">
    <div class="site-header__top-row">
      <div class="site-header__left-nav">
        <!-- Mobile hamburger -->
        <button type="button" class="site-header__menu-toggle" aria-controls="MobileMenu" aria-expanded="false" aria-label="Toggle menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
        <!-- Desktop search -->
        <a href="#" class="site-header__icon" aria-label="Search" style="display: inline-block;" onclick="event.preventDefault(); document.getElementById('HeaderSearchContainer').style.display = document.getElementById('HeaderSearchContainer').style.display === 'none' ? 'block' : 'none';">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </a>
      </div>

      <div class="site-header__logo-container">
        <a href="{{ routes.root_url }}" class="site-header__logo-link" style="text-decoration: none;">
          {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name, class: 'header-logo' }}
          {% else %}
          <div class="site-header__logo-text" style="color: #000; display: flex; flex-direction: column; align-items: center;">
            <span style="font-style:italic; font-weight:900; font-size:2.2rem; letter-spacing:2px; text-transform:uppercase; line-height: 1;">{{ shop.name }}</span>
            <span style="font-size: 0.6rem; letter-spacing: 1px; text-transform: uppercase; margin-top: 2px;">HOUSE OF STREETWEAR</span>
          </div>
          {% endif %}
        </a>
      </div>

      <div class="site-header__icons-container">
        <!-- Account Icon -->
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="site-header__icon" aria-label="Account">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>

        <!-- Shopping Bag Icon -->
        <a href="{{ routes.cart_url }}" class="site-header__icon site-header__cart" id="HeaderCartIcon" style="position: relative;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          <span class="visually-hidden">Cart</span>
          <div class="site-header__cart-count" id="HeaderCartCount" {% if cart.item_count == 0 %}style="display: none;"{% endif %} style="position: absolute; top: -8px; right: -8px; font-size: 0.7rem; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <span aria-hidden="true">{{ cart.item_count }}</span>
          </div>
        </a>
      </div>
    </div>
    
    <!-- Desktop Navigation -->
    <div class="site-header__nav-row">
      <ul class="site-header__nav-list">
        {% for link in section.settings.menu.links %}
          <li style="position: relative;" class="nav-item-dropdown">
            <a href="{{ link.url }}" class="site-header__nav-item {% if link.active %}site-header__nav-item--active{% endif %}" style="display: flex; align-items: center; gap: 5px;">
              {{ link.title }}
              {% if link.links.size > 0 %}
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              {% endif %}
            </a>
            {% if link.links.size > 0 %}
              <ul class="dropdown-menu" style="display: none; position: absolute; top: 100%; left: 50%; transform: translateX(-50%); background: #fff; border: 1px solid #eee; padding: 1rem; list-style: none; min-width: 200px; z-index: 20; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                {% for child_link in link.links %}
                  <li style="margin-bottom: 0.5rem;"><a href="{{ child_link.url }}" style="color: #666; text-decoration: none; font-size: 0.85rem; text-transform: uppercase;">{{ child_link.title }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <!-- Mobile Drawer (Full screen menu) -->
  <div id="MobileMenu" class="mobile-drawer" aria-hidden="true">
    <div class="mobile-drawer__overlay" data-drawer-close></div>
    <div class="mobile-drawer__inner" style="background-color: #fff; color: #000;">
      <div class="mobile-drawer__header" style="border-bottom: 1px solid #eee;">
        <span class="mobile-drawer__title" style="color: #000;">MENU</span>
        <button type="button" class="mobile-drawer__close" data-drawer-close aria-label="Close menu" style="color: #000; background: none; border: none; cursor: pointer;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="mobile-drawer__content">
        <ul class="mobile-nav">
          {% for link in section.settings.menu.links %}
            <li class="mobile-nav__item" style="border-bottom: 1px solid #eee; padding: 1rem 0;">
              {% if link.links.size > 0 %}
                <div style="display: flex; justify-content: space-between; align-items: center;" onclick="var ul = this.nextElementSibling; ul.style.display = ul.style.display === 'none' ? 'block' : 'none';">
                  <a href="{{ link.url }}" class="mobile-nav__link" style="color: #000; font-weight: 500; text-decoration: none; text-transform: uppercase;">{{ link.title }}</a>
                  <button type="button" style="background: none; border: none; font-size: 1.2rem; cursor: pointer;">+</button>
                </div>
                <ul style="display: none; list-style: none; padding-left: 1rem; margin-top: 1rem; width: 100%;">
                  {% for child_link in link.links %}
                    <li style="margin-bottom: 0.8rem;"><a href="{{ child_link.url }}" style="color: #666; text-decoration: none; text-transform: uppercase; font-size: 0.9rem;">{{ child_link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% else %}
                <a href="{{ link.url }}" class="mobile-nav__link" style="color: #000; font-weight: 500; text-decoration: none; text-transform: uppercase;">{{ link.title }}</a>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
