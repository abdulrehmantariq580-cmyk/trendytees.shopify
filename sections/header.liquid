<style>
  .site-header {
    background-color: #ffffff;
    color: #000000;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .site-header.is-scrolled {
    background-color: #ffffff;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }
  .site-header__menu-toggle {
    color: #000;
  }
  .site-header__icon {
    color: #000;
  }
  .site-header__icon:hover {
    color: #666;
  }
  .site-header__logo img, .header-logo-circle {
    border: none;
  }
  .site-header__cart-count {
    background-color: #000;
    color: #fff;
  }
  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }
  .site-header__left-nav {
    display: flex;
    align-items: center;
  }
  .site-header__logo-container {
    display: flex;
    justify-content: center;
  }
  .site-header__icons-container {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.5rem;
  }
  .site-header__menu-toggle {
    display: block; /* Show hamburger even on desktop to match Karvaan if desired, or keep mobile-only */
  }
</style>

<header class="site-header full-width">
  <div class="page-width site-header__inner">
    
    <div class="site-header__left-nav">
      <button type="button" class="site-header__menu-toggle" aria-controls="MobileMenu" aria-expanded="false" aria-label="Toggle menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="site-header__logo-container">
      <a href="{{ routes.root_url }}" class="site-header__logo-link">
        {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name, class: 'header-logo' }}
        {% else %}
        <span class="site-header__logo-text" style="color: #000;">
          <span style="font-style:italic; font-weight:900; font-size:2rem; letter-spacing:2px; text-transform:uppercase;">KARVAAN</span>
        </span>
        {% endif %}
      </a>
    </div>

    <div class="site-header__icons-container">
      <a href="/search" class="site-header__icon" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" class="site-header__icon site-header__cart" id="HeaderCartIcon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M9 20a1 1 0 100-2 1 1 0 000 2zM20 20a1 1 0 100-2 1 1 0 000 2zM1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"></path></svg>
        <span class="visually-hidden">Cart</span>
        <div class="site-header__cart-count" id="HeaderCartCount" {% if cart.item_count == 0 %}style="display: none;"{% endif %}>
          <span aria-hidden="true">{{ cart.item_count }}</span>
          <span class="visually-hidden">items in cart</span>
        </div>
      </a>
    </div>

  </div>

  <!-- Mobile Drawer (Full screen menu) -->
  <div id="MobileMenu" class="mobile-drawer" aria-hidden="true">
    <div class="mobile-drawer__overlay" data-drawer-close></div>
    <div class="mobile-drawer__inner" style="background-color: #fff; color: #000;">
      <div class="mobile-drawer__header" style="border-bottom: 1px solid #eee;">
        <span class="mobile-drawer__title" style="color: #000;">MENU</span>
        <button type="button" class="mobile-drawer__close" data-drawer-close aria-label="Close menu" style="color: #000;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="mobile-drawer__content">
        <ul class="mobile-nav">
          {% for link in section.settings.menu.links %}
            <li class="mobile-nav__item">
              <a href="{{ link.url }}" class="mobile-nav__link" style="color: #000; font-weight: 500;">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
