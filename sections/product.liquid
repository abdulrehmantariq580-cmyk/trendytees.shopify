{%- style -%}
  .main-product {
    padding: 0 0 4rem;
    background-color: #f8f9fa; /* match zoryoo light background */
    font-family: 'Inter', sans-serif;
  }

  .product-layout {
    display: flex;
    flex-direction: column;
  }

  @media screen and (min-width: 900px) {
    .main-product {
      padding: 4rem 0 6rem;
    }
    .product-layout {
      flex-direction: row;
      align-items: flex-start;
      gap: 4rem;
      max-width: var(--page-width);
      margin: 0 auto;
      padding: 0 2rem;
    }
  }

  /* --- Product Media --- */
  .product-media-wrapper {
    width: 100%;
    position: relative;
  }

  @media screen and (min-width: 900px) {
    .product-media-wrapper {
      width: 50%;
      position: sticky;
      top: 2rem;
    }
  }

  .product-image-slider {
    width: 100%;
    position: relative;
  }

  .product-image-slider .swiper-slide {
    display: flex;
    justify-content: center;
    background-color: #ebebeb;
  }

  .product-image-slider img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 70vh; /* reasonable height on mobile */
  }

  .product-slider-pagination {
    position: absolute;
    bottom: 1rem;
    left: 0;
    width: 100%;
    text-align: center;
    z-index: 10;
  }

  .swiper-pagination-bullet {
    background: #000;
    opacity: 0.3;
    width: 8px;
    height: 8px;
    margin: 0 4px;
    border-radius: 50%;
    display: inline-block;
    transition: opacity 0.3s;
  }

  .swiper-pagination-bullet-active {
    opacity: 1;
  }

  /* --- Product Info --- */
  .product-info-wrapper {
    padding: 2rem 1.5rem;
    background-color: #f8f9fa;
  }

  @media screen and (min-width: 900px) {
    .product-info-wrapper {
      width: 50%;
      padding: 0;
    }
  }

  .product-info__vendor {
    font-size: 0.8rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }

  .product-info__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    color: #000;
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .product-info__price-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .product-info__price {
    font-size: 1.4rem;
    font-weight: 700;
    color: #000;
  }

  .product-info__compare-price {
    font-size: 1.1rem;
    color: #999;
    text-decoration: line-through;
  }

  /* --- Variant Selectors (Size) --- */
  .product-option-block {
    margin-bottom: 2rem;
  }

  .product-option-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .product-option-label {
    font-size: 1rem;
    font-weight: 600;
    color: #000;
    text-transform: capitalize;
  }

  .product-option-guide {
    font-size: 0.85rem;
    color: #666;
    text-decoration: underline;
    cursor: pointer;
  }

  .pill-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .pill-btn {
    background: transparent;
    border: 1px solid #ddd;
    border-radius: 4px; /* Zoryoo has slight rounded corners, not fully rounded */
    padding: 10px 20px;
    font-size: 0.95rem;
    color: #333;
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 48px;
    text-align: center;
  }

  .pill-btn:hover {
    border-color: #000;
  }

  .pill-btn.is-active {
    background: #000;
    color: #fff;
    border-color: #000;
  }

  /* --- Quantity --- */
  .quantity-wrapper {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .quantity-selector {
    display: inline-flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 4px;
    height: 48px;
    background: #fff;
  }

  .quantity-btn {
    background: transparent;
    border: none;
    width: 40px;
    height: 100%;
    font-size: 1.2rem;
    cursor: pointer;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .quantity-input {
    width: 40px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 1rem;
    -moz-appearance: textfield;
  }
  .quantity-input::-webkit-outer-spin-button,
  .quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* --- Actions --- */
  .product-form__actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .btn--add-to-cart,
  .btn--buy-it-now {
    width: 100%;
    box-sizing: border-box;
    padding: 16px;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn--add-to-cart {
    background: #000;
    color: #fff;
    border: 1px solid #000;
  }

  .btn--add-to-cart:hover:not([disabled]) {
    background: #333;
  }

  .btn--buy-it-now {
    background: #fff;
    color: #000;
    border: 1px solid #000;
  }

  .btn--buy-it-now:hover {
    background: #f5f5f5;
  }

  /* --- Accordion (Collapsible Tabs) --- */
  .product-accordion {
    border-top: 1px solid #e0e0e0;
  }

  .accordion-item {
    border-bottom: 1px solid #e0e0e0;
  }

  .accordion-header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    color: #000;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .accordion-icon {
    width: 20px;
    height: 20px;
    position: relative;
  }

  .accordion-icon::before,
  .accordion-icon::after {
    content: '';
    position: absolute;
    background-color: #000;
    transition: transform 0.3s ease;
  }

  .accordion-icon::before {
    top: 9px;
    left: 4px;
    width: 12px;
    height: 2px;
  }

  .accordion-icon::after {
    top: 4px;
    left: 9px;
    width: 2px;
    height: 12px;
  }

  .accordion-header.is-active .accordion-icon::after {
    transform: rotate(90deg);
    opacity: 0;
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }

  .accordion-content-inner {
    padding-bottom: 1.5rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #555;
  }
{%- endstyle -%}

<section class="main-product" id="MainProduct-{{ section.id }}">
  <div class="page-width">
    <nav class="breadcrumb" role="navigation" aria-label="breadcrumbs" style="padding: 1rem 0; font-size: 0.85rem; color: #666;">
      <a href="/" title="Home" style="color: #666; text-decoration: none;">Home</a>
      <span aria-hidden="true" style="margin: 0 5px;">/</span>
      {% if collection %}
        <a href="{{ collection.url }}" style="color: #666; text-decoration: none;">{{ collection.title }}</a>
        <span aria-hidden="true" style="margin: 0 5px;">/</span>
      {% endif %}
      <span style="color: #000;">{{ product.title }}</span>
    </nav>
  </div>

  <div class="product-layout">
    
    <!-- Product Media (Left) -->
    <div class="product-media-wrapper">
      <div class="swiper product-image-slider">
        <div class="swiper-wrapper">
          {%- if product.images.size > 0 -%}
            {%- for image in product.images -%}
              <div class="swiper-slide">
                <img src="{{ image | image_url: width: 1200 }}" alt="{{ image.alt | escape }}" width="{{ image.width }}" height="{{ image.height }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="swiper-slide">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
        <div class="product-slider-pagination"></div>
      </div>
    </div>

    <!-- Product Info (Right) -->
    <div class="product-info-wrapper">
      <div class="product-info__vendor">{{ product.vendor | default: shop.name }}</div>
      <h1 class="product-info__title">{{ product.title }}</h1>
      
      <div class="product-info__reviews" style="display: flex; align-items: center; gap: 5px; margin-bottom: 1.5rem; font-size: 0.9rem; color: #666;">
        <span style="color: #FFB800;">★★★★★</span>
        <span>(1 review)</span>
      </div>
      
      <div class="product-info__price-container">
        <span class="product-info__price" id="ProductPrice">
          {{ product.selected_or_first_available_variant.price | money }}
        </span>
        <span class="product-info__compare-price" id="ComparePrice" {% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}style="display:none;"{% endunless %}>
          {{ product.selected_or_first_available_variant.compare_at_price | money }}
        </span>
      </div>

      {% form 'product', product, id: 'AddToCartForm', class: 'product-form' %}
        <input type="hidden" name="id" id="ProductSelect" value="{{ product.selected_or_first_available_variant.id }}">
        
        {%- unless product.has_only_default_variant -%}
          <div class="product-options">
            {%- for option in product.options_with_values -%}
              <div class="product-option-block">
                <div class="product-option-header">
                  <label class="product-option-label">{{ option.name }}</label>
                  {%- if option.name == 'Size' or option.name == 'size' -%}
                    <span class="product-option-guide">Size Guide</span>
                  {%- endif -%}
                </div>
                <div class="pill-group" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    {%- assign is_selected = false -%}
                    {%- if option.selected_value == value -%}
                      {%- assign is_selected = true -%}
                    {%- endif -%}
                    <button type="button" class="pill-btn {% if is_selected %}is-active{% endif %}" data-value="{{ value | escape }}">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="product-form__actions">
          <div class="quantity-wrapper" style="display: none;">
            <label class="quantity-label" for="Quantity" style="display: none;">Quantity</label>
            <div class="quantity-selector">
              <button type="button" class="quantity-btn minus" aria-label="Decrease quantity">&minus;</button>
              <input type="number" id="Quantity" name="quantity" value="1" min="1" class="quantity-input">
              <button type="button" class="quantity-btn plus" aria-label="Increase quantity">+</button>
            </div>
          </div>

          <button type="submit" name="add" id="AddToCart" class="btn--add-to-cart" {% unless product.selected_or_first_available_variant.available %}disabled="disabled"{% endunless %}>
            <span id="AddToCartText">
              {% if product.selected_or_first_available_variant.available %}
                Add to cart
              {% else %}
                Sold out
              {% endif %}
            </span>
          </button>
          
          <button type="button" class="btn--buy-it-now" onclick="document.querySelector('.shopify-payment-button__button').click();" {% unless product.selected_or_first_available_variant.available %}style="display:none;"{% endunless %}>
            Buy it now
          </button>
          
          <div style="display:none;">
            {{ form | payment_button }}
          </div>
        </div>
      {% endform %}

      <!-- Accordions -->
      <div class="product-accordion">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'description' -%}
              <div class="accordion-item" {{ block.shopify_attributes }}>
                <button class="accordion-header" aria-expanded="false">
                  Description
                  <span class="accordion-icon"></span>
                </button>
                <div class="accordion-content">
                  <div class="accordion-content-inner">
                    {{ product.description }}
                  </div>
                </div>
              </div>
            {%- when 'text' -%}
              <div class="accordion-item" {{ block.shopify_attributes }}>
                <button class="accordion-header" aria-expanded="false">
                  {{ block.settings.title }}
                  <span class="accordion-icon"></span>
                </button>
                <div class="accordion-content">
                  <div class="accordion-content-inner">
                    {{ block.settings.text }}
                  </div>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<script type="application/json" id="ProductJson-{{ section.id }}">
  {{ product | json }}
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 1. Swiper Slider initialization
    if (typeof Swiper !== 'undefined') {
      new Swiper('.product-image-slider', {
        loop: true,
        pagination: {
          el: '.product-slider-pagination',
          clickable: true,
        },
      });
    }

    // 2. Variant Selector Logic
    const productJsonEl = document.getElementById('ProductJson-{{ section.id }}');
    if (!productJsonEl) return;
    const productData = JSON.parse(productJsonEl.textContent);
    const hiddenSelect = document.getElementById('ProductSelect');
    const pillGroups = document.querySelectorAll('.pill-group');
    
    const priceEl = document.getElementById('ProductPrice');
    const comparePriceEl = document.getElementById('ComparePrice');
    const addToCartBtn = document.getElementById('AddToCart');
    const addToCartText = document.getElementById('AddToCartText');
    const buyItNowBtn = document.querySelector('.btn--buy-it-now');

    let currentOptions = [];

    pillGroups.forEach((group, index) => {
      const pills = group.querySelectorAll('.pill-btn');
      const activePill = group.querySelector('.pill-btn.is-active');
      if (activePill) {
        currentOptions[index] = activePill.getAttribute('data-value');
      }

      pills.forEach(pill => {
        pill.addEventListener('click', function() {
          pills.forEach(p => p.classList.remove('is-active'));
          this.classList.add('is-active');
          currentOptions[index] = this.getAttribute('data-value');

          const matchedVariant = productData.variants.find(variant => {
            return variant.options.every((opt, i) => opt === currentOptions[i]);
          });

          if (matchedVariant) {
            hiddenSelect.value = matchedVariant.id;

            const formatter = new Intl.NumberFormat('en-US', {
              style: 'currency',
              currency: Shopify.currency.active || 'USD',
              minimumFractionDigits: 2
            });

            priceEl.textContent = formatter.format(matchedVariant.price / 100);

            if (matchedVariant.compare_at_price > matchedVariant.price) {
              comparePriceEl.textContent = formatter.format(matchedVariant.compare_at_price / 100);
              comparePriceEl.style.display = 'inline-block';
            } else {
              comparePriceEl.style.display = 'none';
            }

            if (matchedVariant.available) {
              addToCartBtn.disabled = false;
              addToCartText.textContent = 'Add to cart';
              if(buyItNowBtn) buyItNowBtn.style.display = 'flex';
            } else {
              addToCartBtn.disabled = true;
              addToCartText.textContent = 'Sold out';
              if(buyItNowBtn) buyItNowBtn.style.display = 'none';
            }

            // Image slider update
            if (matchedVariant.featured_image && window.swiper) {
              // implementation depends on swiper instance saving, simplified here.
            }
          }
        });
      });
    });

    // 3. Accordions
    const accordionHeaders = document.querySelectorAll('.accordion-header');
    accordionHeaders.forEach(header => {
      header.addEventListener('click', function() {
        const content = this.nextElementSibling;
        
        // Close others (optional)
        // accordionHeaders.forEach(otherHeader => {
        //   if(otherHeader !== this) {
        //     otherHeader.classList.remove('is-active');
        //     otherHeader.nextElementSibling.style.maxHeight = null;
        //   }
        // });

        this.classList.toggle('is-active');
        
        if (content.style.maxHeight) {
          content.style.maxHeight = null;
        } else {
          content.style.maxHeight = content.scrollHeight + "px";
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [],
  "blocks": [
    {
      "type": "description",
      "name": "Product Description",
      "limit": 1
    },
    {
      "type": "text",
      "name": "Collapsible Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Shipping",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Standard shipping takes 3-5 business days. Free shipping on orders over $50.</p>",
          "label": "Text"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "description" },
      { "type": "text", "settings": { "title": "Material & Care", "text": "<p>100% Premium Cotton. Machine wash cold. Do not bleach.</p>" } },
      { "type": "text", "settings": { "title": "Shipping", "text": "<p>Standard shipping takes 3-5 business days. Free shipping on orders over $50.</p>" } }
    ]
  }
}
{% endschema %}
