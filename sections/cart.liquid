<div class="page-width cart-page-container">
  <div class="cart-page-header">
    <h1 class="cart-page-title">Your Cart</h1>
    <a href="{{ routes.all_products_collection_url }}" class="cart-page-continue">Continue Shopping</a>
  </div>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-page-form">
      <div class="cart-page-content">
        <div class="cart-table-wrapper">
          <table class="cart-table">
            <thead>
              <tr>
                <th class="col-product">Product</th>
                <th class="col-quantity">Quantity</th>
                <th class="col-total">Total</th>
              </tr>
            </thead>
            <tbody>
              {% for item in cart.items %}
                <tr class="cart-item">
                  <td class="cart-item-product">
                    <div class="cart-item-image-wrapper">
                      {% if item.image %}
                        <img src="{{ item.image | image_url: width: 200 }}" width="{{ item.image.width }}" height="{{ item.image.height }}" alt="{{ item.title | escape }}" loading="lazy" class="cart-item-image">
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </div>
                    
                    <div class="cart-item-details">
                      <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                      {% unless item.product.has_only_default_variant %}
                        <p class="cart-item-variant">{{ item.variant.title }}</p>
                      {% endunless %}
                      <p class="cart-item-price-mobile">{{ item.final_price | money }}</p>
                    </div>
                  </td>
                  
                  <td class="cart-item-quantity">
                    <div class="cart-item-qty-flex">
                      <div class="qty-wrapper">
                        <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="qty-btn" aria-label="Decrease quantity">-</a>
                        <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" class="qty-input" aria-label="Item quantity">
                        <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="qty-btn" aria-label="Increase quantity">+</a>
                      </div>
                      <a href="{{ item.url_to_remove }}" class="cart-item-remove" aria-label="Remove item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px;">
                          <polyline points="3 6 5 6 21 6"></polyline>
                          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                          <line x1="10" y1="11" x2="10" y2="17"></line>
                          <line x1="14" y1="11" x2="14" y2="17"></line>
                        </svg>
                      </a>
                    </div>
                  </td>
                  
                  <td class="cart-item-total">
                    <span class="cart-item-final-price">{{ item.final_line_price | money }}</span>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        
        <div class="cart-footer">
          <div class="order-summary-box">
            <h2 class="order-summary-title">Order Summary</h2>
            <div class="order-summary-row">
              <span>Subtotal</span>
              <span class="order-summary-price">{{ cart.total_price | money }}</span>
            </div>
            
            <p class="order-summary-note">Taxes and shipping calculated at checkout.</p>
            <button type="submit" name="checkout" class="button button--primary cart-checkout-btn">Proceed to Checkout</button>
          </div>
        </div>
      </div>
    </form>
  {% else %}
    <div class="cart-page-empty">
      <div class="empty-cart-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="9" cy="21" r="2"></circle>
          <circle cx="20" cy="21" r="2"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
      </div>
      <h2 class="empty-cart-title">Your cart is feeling light</h2>
      <p class="empty-cart-subtitle">Let's add some trendy items to it.</p>
      <a href="{{ routes.all_products_collection_url }}" class="button button--primary cart-empty-btn">Shop Now</a>
    </div>
  {% endif %}
</div>

<style>
  .cart-page-container {
    padding: 60px 20px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .cart-page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    border-bottom: 2px solid #000;
    padding-bottom: 15px;
  }
  .cart-page-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0;
  }
  .cart-page-continue {
    font-size: 1rem;
    text-decoration: underline;
    text-transform: uppercase;
    font-weight: 500;
  }
  .cart-page-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .cart-table-wrapper {
    width: 100%;
    overflow-x: auto;
  }
  .cart-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }
  .cart-table th {
    padding-bottom: 15px;
    border-bottom: 1px solid #eee;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.9rem;
    color: #666;
  }
  .col-total {
    text-align: right;
  }
  .col-quantity {
    text-align: center;
  }
  .cart-item td {
    padding: 30px 0;
    border-bottom: 1px solid #f5f5f5;
    vertical-align: middle;
  }
  .cart-item-product {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .cart-item-image-wrapper {
    display: inline-block;
    width: 100px;
    height: 120px;
    background: #f9f9f9;
    flex-shrink: 0;
  }
  .cart-item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-item-title {
    font-size: 1.1rem;
    font-weight: 600;
    display: block;
    margin-bottom: 5px;
    text-decoration: none;
    color: #000;
    max-width: 350px;
    line-height: 1.4;
  }
  .cart-item-variant {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 0;
  }
  .cart-item-price-mobile {
    display: none;
  }
  .cart-item-quantity {
    text-align: center;
  }
  .cart-item-qty-flex {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
  }
  .qty-wrapper {
    display: inline-flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 30px;
    overflow: hidden;
  }
  .qty-btn {
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    background: #fff;
    color: #000;
    cursor: pointer;
    text-decoration: none;
  }
  .qty-btn:hover {
    background: #f0f0f0;
  }
  .qty-input {
    width: 40px;
    height: 35px;
    text-align: center;
    border: none;
    font-size: 1rem;
    font-weight: 500;
    padding: 0;
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .cart-item-remove {
    color: #ff4d4f;
    padding: 10px;
    background: rgba(255, 77, 79, 0.05);
    border-radius: 50%;
    display: flex;
    transition: all 0.3s;
  }
  .cart-item-remove:hover {
    background: rgba(255, 77, 79, 0.15);
  }
  .cart-item-total {
    text-align: right;
    font-size: 1.2rem;
    font-weight: 600;
  }
  .cart-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 20px;
  }
  .order-summary-box {
    background: #fff;
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    box-sizing: border-box;
    width: 400px;
    max-width: 100%;
  }
  .order-summary-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 20px;
  }
  .order-summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 20px;
  }
  .order-summary-note {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 20px;
    text-align: center;
  }
  .cart-checkout-btn {
    display: block;
    box-sizing: border-box;
    width: 100%;
    padding: 18px !important;
    font-size: 1.1rem !important;
    border-radius: 50px !important;
    background: #000 !important;
    color: #fff !important;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .cart-checkout-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.3);
  }
  .cart-page-empty {
    text-align: center;
    padding: 100px 20px;
    background: #fafafa;
    border-radius: 20px;
    margin: 40px auto;
    max-width: 600px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }
  .empty-cart-icon {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 25px;
    animation: floatCart 3s ease-in-out infinite;
  }
  .empty-cart-icon svg {
    width: 80px;
    height: 80px;
    color: #111;
  }
  .empty-cart-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 10px;
    letter-spacing: -0.5px;
    color: #000;
  }
  .empty-cart-subtitle {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 30px;
  }
  @keyframes floatCart {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }
  .cart-empty-btn {
    display: inline-block;
    padding: 15px 40px;
    background: #000;
    color: #fff;
    border-radius: 40px;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .cart-empty-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    background: #222;
  }

  @media screen and (max-width: 768px) {
    .cart-table thead {
      display: none;
    }
    .cart-item {
      display: flex;
      flex-direction: column;
      border-bottom: 1px solid #eee;
      padding: 20px 0;
    }
    .cart-item td {
      display: block;
      padding: 10px 0;
      border: none;
      text-align: left;
    }
    .cart-item-qty-flex {
      justify-content: flex-start;
    }
    td.cart-item-total {
      display: none !important;
    }
    .cart-item-price-mobile {
      display: block;
      font-weight: 600;
      margin-top: 5px;
    }
    .cart-footer {
      justify-content: center;
    }
    .order-summary-box {
      width: 100%;
    }
    .cart-page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
