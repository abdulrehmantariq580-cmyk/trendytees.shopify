<div class="page-width cart-page-container">
  <div class="cart-page-header">
    <h1 class="cart-page-title">Your Cart</h1>
    <a href="{{ routes.all_products_collection_url }}" class="cart-page-continue">Continue Shopping</a>
  </div>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-page-form">
      <div class="cart-page-content">
        <div class="cart-page-items">
          <div class="cart-items-header">
            <span class="col-product">Product</span>
            <span class="col-quantity">Quantity</span>
            <span class="col-total">Total</span>
          </div>
          
          {% for item in cart.items %}
            <div class="cart-item">
              <div class="cart-item-product">
                <div class="cart-item-image-wrapper">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy" class="cart-item-image">
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                
                <div class="cart-item-details">
                  <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                  {% unless item.product.has_only_default_variant %}
                    <p class="cart-item-variant">{{ item.variant.title }}</p>
                  {% endunless %}
                  <p class="cart-item-price-mobile">{{ item.final_price | money }}</p>
                </div>
              </div>
              
              <div class="cart-item-quantity">
                <div class="qty-wrapper">
                  <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="qty-btn" aria-label="Decrease quantity">-</a>
                  <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" class="qty-input" aria-label="Item quantity">
                  <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="qty-btn" aria-label="Increase quantity">+</a>
                </div>
                <a href="{{ item.url_to_remove }}" class="cart-item-remove" aria-label="Remove item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px;">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    <line x1="10" y1="11" x2="10" y2="17"></line>
                    <line x1="14" y1="11" x2="14" y2="17"></line>
                  </svg>
                </a>
              </div>
              
              <div class="cart-item-total">
                <span class="cart-item-final-price">{{ item.final_line_price | money }}</span>
              </div>
            </div>
          {% endfor %}
          
          <div class="cart-page-actions">
            <button type="submit" name="update" class="button button--secondary cart-update-btn">Update Cart</button>
          </div>
        </div>
        
        <div class="cart-page-sidebar">
          <div class="order-summary-box">
            <h2 class="order-summary-title">Order Summary</h2>
            <div class="order-summary-row">
              <span>Subtotal</span>
              <span class="order-summary-price">{{ cart.total_price | money }}</span>
            </div>
            <p class="order-summary-note">Taxes and shipping calculated at checkout.</p>
            <button type="submit" name="checkout" class="button button--primary cart-checkout-btn">Proceed to Checkout</button>
          </div>
        </div>
      </div>
    </form>
  {% else %}
    <div class="cart-page-empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width: 80px; height: 80px; color: #ccc; margin-bottom: 20px;">
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
      <h2>Your cart is currently empty.</h2>
      <a href="{{ routes.all_products_collection_url }}" class="button button--primary cart-empty-btn">Start Shopping</a>
    </div>
  {% endif %}
</div>

<style>
  .cart-page-container {
    padding: 60px 20px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .cart-page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 40px;
    border-bottom: 2px solid #000;
    padding-bottom: 15px;
  }
  .cart-page-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0;
  }
  .cart-page-continue {
    font-size: 1rem;
    text-decoration: underline;
    text-transform: uppercase;
    font-weight: 500;
  }
  .cart-page-content {
    display: flex;
    gap: 50px;
    align-items: flex-start;
  }
  .cart-page-items {
    flex: 1;
  }
  .cart-items-header {
    display: grid;
    grid-template-columns: 3fr 1fr 1fr;
    border-bottom: 1px solid #eee;
    padding-bottom: 15px;
    margin-bottom: 20px;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.9rem;
    color: #666;
  }
  .cart-item {
    display: grid;
    grid-template-columns: 3fr 1fr 1fr;
    align-items: center;
    border-bottom: 1px solid #f5f5f5;
    padding: 20px 0;
  }
  .cart-item-product {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .cart-item-image-wrapper {
    display: inline-block;
    width: 100px;
    height: 120px;
    background: #f9f9f9;
  }
  .cart-item-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-item-details {
    display: inline-block;
    vertical-align: top;
    max-width: 100%;
  }
  .cart-item-title {
    font-size: 1.1rem;
    font-weight: 600;
    display: block;
    margin-bottom: 5px;
  }
  .cart-item-variant {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 0;
  }
  .cart-item-price-mobile {
    display: none;
  }
  .cart-item-quantity {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .qty-wrapper {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 30px;
    overflow: hidden;
  }
  .qty-btn {
    padding: 8px 15px;
    font-size: 1.2rem;
    background: #fff;
    color: #000;
    cursor: pointer;
    text-decoration: none;
  }
  .qty-btn:hover {
    background: #f0f0f0;
  }
  .qty-input {
    width: 40px;
    text-align: center;
    border: none;
    font-size: 1rem;
    font-weight: 500;
    padding: 8px 0;
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .cart-item-remove {
    color: #ff4d4f;
    padding: 10px;
    background: rgba(255, 77, 79, 0.05);
    border-radius: 50%;
    display: flex;
    transition: all 0.3s;
  }
  .cart-item-remove:hover {
    background: rgba(255, 77, 79, 0.15);
  }
  .cart-item-total {
    text-align: right;
    font-size: 1.2rem;
    font-weight: 600;
  }
  .cart-page-actions {
    margin-top: 30px;
    text-align: right;
  }
  .cart-update-btn {
    background: transparent;
    border: 1px solid #000;
    color: #000;
    padding: 10px 30px;
    border-radius: 30px;
    font-weight: 500;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.3s;
  }
  .cart-update-btn:hover {
    background: #000;
    color: #fff;
  }
  
  /* Sidebar Summary */
  .cart-page-sidebar {
    width: 350px;
  }
  .order-summary-box {
    background: #fff;
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
  }
  .order-summary-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 1px solid #eee;
  }
  .order-summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 15px;
  }
  .order-summary-note {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 30px;
    text-align: center;
  }
  .cart-checkout-btn {
    width: 100%;
    padding: 18px !important;
    font-size: 1.1rem !important;
    border-radius: 50px !important;
    background: #000 !important;
    color: #fff !important;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .cart-checkout-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.3);
  }
  
  /* Empty State */
  .cart-page-empty {
    text-align: center;
    padding: 80px 20px;
  }
  .cart-empty-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 15px 40px;
    background: #000;
    color: #fff;
    border-radius: 40px;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
  }

  @media screen and (max-width: 900px) {
    .cart-page-content {
      flex-direction: column;
    }
    .cart-page-sidebar {
      width: 100%;
      margin-top: 30px;
    }
    .cart-items-header {
      display: none;
    }
    .cart-item {
      display: flex;
      flex-direction: column;
      position: relative;
    }
    .cart-item-image-wrapper {
      width: 80px;
      height: 100px;
      margin-right: 15px;
    }
    .cart-item-details {
      max-width: calc(100% - 95px);
    }
    .cart-item-price-mobile {
      display: block;
      font-weight: 600;
      margin-top: 5px;
    }
    .cart-item-total {
      display: none;
    }
    .cart-item-quantity {
      margin-top: 20px;
      width: 100%;
      justify-content: space-between;
    }
    .cart-page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
