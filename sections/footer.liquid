<footer class="site-footer">
  <div class="page-width">
    <div class="footer__content">
      {% for block in section.blocks %}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {% case block.type %}
            {% when 'text' %}
              <div class="footer-block__details">
                {% if block.settings.heading != blank %}
                  <h3 class="footer-block__heading">{{ block.settings.heading | escape }}</h3>
                {% endif %}
                <div class="footer-block__text rte">
                  {{ block.settings.text }}
                </div>
              </div>

            {% when 'link_list' %}
              <div class="footer-block__links">
                {% if block.settings.heading != blank %}
                  <h3 class="footer-block__heading">{{ block.settings.heading | escape }}</h3>
                {% endif %}
                {% if block.settings.menu != blank %}
                  <ul class="footer-block__menu">
                    {% for link in block.settings.menu.links %}
                      <li>
                        <a href="{{ link.url }}" class="footer-block__menu-link">
                          {{ link.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>

            {% when 'contact' %}
              <div class="footer-block__contact">
                {% if block.settings.heading != blank %}
                  <h3 class="footer-block__heading">{{ block.settings.heading | escape }}</h3>
                {% endif %}
                <ul class="contact-list" style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem;">
                  {% if block.settings.address != blank %}
                    <li><strong>Location:</strong> {{ block.settings.address }}</li>
                  {% endif %}
                  {% if block.settings.email != blank %}
                    <li><strong>Email:</strong> <a href="mailto:{{ block.settings.email }}" style="color: inherit; text-decoration: none;">{{ block.settings.email }}</a></li>
                  {% endif %}
                  {% if block.settings.phone != blank %}
                    <li><strong>Phone:</strong> <a href="tel:{{ block.settings.phone }}" style="color: inherit; text-decoration: none;">{{ block.settings.phone }}</a></li>
                  {% endif %}
                </ul>
                <div class="footer-block__socials" style="margin-top: 1.5rem;">
                  {% if settings.social_facebook_link != blank %}
                    <a href="{{ settings.social_facebook_link }}" class="social-link" aria-label="Facebook">FB</a>
                  {% endif %}
                  {% if settings.social_instagram_link != blank %}
                    <a href="{{ settings.social_instagram_link }}" class="social-link" aria-label="Instagram">IG</a>
                  {% endif %}
                  {% if settings.social_twitter_link != blank %}
                    <a href="{{ settings.social_twitter_link }}" class="social-link" aria-label="Twitter">TW</a>
                  {% endif %}
                </div>
              </div>
          {% endcase %}
        </div>
      {% endfor %}
    </div>

    <div class="footer__bottom">
      <div class="footer__socials">
        {% if settings.social_facebook_link != blank %}
          <a href="{{ settings.social_facebook_link }}" class="social-link" aria-label="Facebook">FB</a>
        {% endif %}
        {% if settings.social_instagram_link != blank %}
          <a href="{{ settings.social_instagram_link }}" class="social-link" aria-label="Instagram">IG</a>
        {% endif %}
        {% if settings.social_twitter_link != blank %}
          <a href="{{ settings.social_twitter_link }}" class="social-link" aria-label="Twitter">TW</a>
        {% endif %}
      </div>

      <div class="footer__copyright">
        <small>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}</small>
      </div>

      <div class="footer__payment">
        {% if section.settings.show_payment_icons %}
          <ul class="list-payment">
            {% for type in shop.enabled_payment_types %}
              <li class="list-payment__item">
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:general.footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "About Us",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Share store details, promotions, or brand content with your customers.</p>",
          "label": "Text"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact Details",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Contact Us",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "address",
          "default": "123 Trendy Street, Fashion City",
          "label": "Address"
        },
        {
          "type": "text",
          "id": "email",
          "default": "hello@trendytees.com",
          "label": "Email Address"
        },
        {
          "type": "text",
          "id": "phone",
          "default": "+1 (555) 123-4567",
          "label": "Phone Number"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "text"
      },
      {
        "type": "link_list"
      },
      {
        "type": "contact"
      }
    ]
  }
}
{% endschema %}
