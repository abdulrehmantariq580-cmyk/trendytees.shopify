<footer class="site-footer">
  <div class="footer__newsletter page-width">
    <h2 class="footer__newsletter-heading">{{ section.settings.newsletter_heading }}</h2>
    <p class="footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
    <div class="footer__newsletter-form">
      <form action="/contact#contact_form" method="post" id="contact_form" accept-charset="UTF-8" class="contact-form">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="footer__newsletter-input-group">
          <input type="email" name="contact[email]" id="Email" class="footer__newsletter-input" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="Email" autocorrect="off" autocapitalize="off">
          <button type="submit" class="footer__newsletter-btn" name="commit" id="Subscribe">
            <svg viewBox="0 0 14 10" fill="none" aria-hidden="true" focusable="false" class="icon icon-arrow" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path></svg>
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="page-width">
    <div class="footer__content">
      {% for block in section.blocks %}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {% case block.type %}
            {% when 'contact' %}
              <h3 class="footer-block__heading">{{ block.settings.heading | escape }}</h3>
              <ul class="contact-list">
                {% if block.settings.address != blank %}
                  <li><strong>Address:</strong> {{ block.settings.address }}</li>
                {% endif %}
                {% if block.settings.phone != blank %}
                  <li><strong>Hotline:</strong> <a href="tel:{{ block.settings.phone }}">{{ block.settings.phone }}</a></li>
                {% endif %}
                {% if block.settings.email != blank %}
                  <li><strong>Email:</strong> <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a></li>
                {% endif %}
              </ul>

            {% when 'link_list' %}
              <h3 class="footer-block__heading">{{ block.settings.heading | escape }}</h3>
              {% if block.settings.menu != blank %}
                <ul class="footer-block__menu">
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}" class="footer-block__menu-link">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
              
            {% when 'text' %}
              {% if block.settings.logo != blank %}
                 {{ block.settings.logo | image_url: width: 300 | image_tag: alt: shop.name, class: "footer-block__logo" }}
              {% endif %}
              {% if block.settings.heading != blank %}
                <h3 class="footer-block__heading">{{ block.settings.heading | escape }}</h3>
              {% endif %}
              <div class="footer-block__text rte">
                {{ block.settings.text }}
              </div>
          {% endcase %}
        </div>
      {% endfor %}
    </div>

    <div class="footer__bottom">
      <div class="footer__socials">
        {% if settings.social_facebook_link != blank %}
          <a href="{{ settings.social_facebook_link }}" class="social-link" aria-label="Facebook">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
        {% endif %}
        {% if settings.social_instagram_link != blank %}
          <a href="{{ settings.social_instagram_link }}" class="social-link" aria-label="Instagram">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-instagram"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        {% endif %}
      </div>

      <div class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }} 
        <span class="footer__separator">·</span> <a href="/policies/refund-policy">Refund policy</a>
        <span class="footer__separator">·</span> <a href="/policies/privacy-policy">Privacy policy</a>
        <span class="footer__separator">·</span> <a href="/policies/terms-of-service">Terms of service</a>
        <span class="footer__separator">·</span> <a href="/policies/shipping-policy">Shipping policy</a>
        <span class="footer__separator">·</span> <a href="/pages/contact">Contact information</a>
      </div>
    </div>
  </div>
</footer>

{%- style -%}
  .site-footer {
    background-color: #000000;
    color: #ffffff;
    padding: 6rem 0 3rem;
    font-family: inherit;
  }

  /* Newsletter Section */
  .footer__newsletter {
    text-align: center;
    margin-bottom: 6rem;
  }
  
  .footer__newsletter-heading {
    color: #ffffff;
    font-size: 2.2rem;
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .footer__newsletter-text {
    color: #b0b0b0;
    font-size: 1rem;
    margin-bottom: 2.5rem;
  }

  .footer__newsletter-form {
    max-width: 400px;
    margin: 0 auto;
  }

  .footer__newsletter-input-group {
    position: relative;
    display: flex;
    align-items: center;
    border: 1px solid #444;
    border-radius: 50px;
    overflow: hidden;
  }

  .footer__newsletter-input {
    width: 100%;
    background: transparent;
    border: none;
    color: #ffffff;
    padding: 12px 20px;
    font-size: 1rem;
    outline: none;
  }

  .footer__newsletter-input::placeholder {
    color: #888;
  }

  .footer__newsletter-btn {
    background: transparent;
    border: none;
    color: #ffffff;
    padding: 0 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .footer__newsletter-btn svg {
    width: 16px;
    height: 16px;
  }

  /* Main Grid */
  .footer__content {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 5rem;
  }

  .footer-block__heading {
    color: #ffffff;
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-list li {
    color: #b0b0b0;
    font-size: 0.95rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .contact-list a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s;
  }

  .contact-list a:hover {
    color: #ffffff;
  }
  
  .contact-list strong {
    color: #ffffff;
    font-weight: 500;
  }

  .footer-block__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-block__menu li {
    margin-bottom: 0.8rem;
  }

  .footer-block__menu-link {
    color: #b0b0b0;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s;
  }

  .footer-block__menu-link:hover {
    color: #ffffff;
  }

  .footer-block__logo {
    max-width: 100%;
    height: auto;
    display: block;
    margin-top: 2rem;
  }

  /* Bottom Section */
  .footer__bottom {
    text-align: center;
    padding-top: 3rem;
  }

  .footer__socials {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .social-link {
    color: #ffffff;
    text-decoration: none;
    transition: color 0.3s;
  }

  .social-link:hover {
    color: #aaaaaa;
  }
  
  .social-link svg {
    width: 20px;
    height: 20px;
  }

  .footer__copyright {
    color: #888888;
    font-size: 0.8rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
  }

  .footer__copyright a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer__copyright a:hover {
    color: #ffffff;
  }
  
  .footer__separator {
    color: #555;
  }

  @media screen and (max-width: 990px) {
    .footer__content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Subscribe to our emails"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Be the first to know about new collections and exclusive offers."
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text/Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact Details",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Karvaan Clothing",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "address",
          "default": "Block 19, Gulistan-E-Johar, Karachi",
          "label": "Address"
        },
        {
          "type": "text",
          "id": "phone",
          "default": "0310-3000547",
          "label": "Phone Number"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email Address"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "contact"
      },
      {
        "type": "link_list"
      },
      {
        "type": "link_list"
      },
      {
        "type": "text"
      }
    ]
  }
}
{% endschema %}
