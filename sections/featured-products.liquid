<section class="featured-products" id="FeaturedProducts-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div class="featured-products__header">
        <div style="text-align: center; width: 100%;">
          <h2 class="featured-products__title" data-animate-text style="font-size: clamp(1.8rem, 4vw, 2.5rem); font-style: normal; font-weight: 700; text-transform: uppercase;">{{ section.settings.title }}</h2>
          {%- if section.settings.subtitle != blank -%}
            <p class="featured-products__subtitle" style="font-size: 1.1rem; color: #666; margin-top: 1rem; text-transform: uppercase; letter-spacing: 1px;">{{ section.settings.subtitle }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="product-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'shopify_product' -%}
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              {% render 'product-card', product: product %}
            {%- else -%}
              <div class="product-card" {{ block.shopify_attributes }}>
                <div class="product-card__image-wrapper">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg product-card__image' }}
                </div>
                <div class="product-card__info">
                  <h3 class="product-card__title">Select a Product</h3>
                  <p class="product-card__price">$0.00</p>
                </div>
              </div>
            {%- endif -%}
          {%- elsif block.type == 'custom_product' -%}
            <a href="{{ block.settings.link | default: '#' }}" class="product-card" {{ block.shopify_attributes }}>
              <div class="product-card__image-wrapper">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'product-card__image' }}
                {%- else -%}
                  {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg product-card__image' }}
                {%- endif -%}
              </div>
              <div class="product-card__info">
                <h3 class="product-card__title">{{ block.settings.title }}</h3>
                <p class="product-card__price">{{ block.settings.price }}</p>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign collection = collections[section.settings.collection] -%}
        {%- if collection != blank and collection.products_count > 0 -%}
          {%- for product in collection.products limit: section.settings.products_to_show -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..section.settings.products_to_show) -%}
            <div class="product-card">
              <div class="product-card__image-wrapper">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg product-card__image' }}
              </div>
              <div class="product-card__info">
                <h3 class="product-card__title">Example T-Shirt</h3>
                <p class="product-card__price">$29.99</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all -%}
      <div style="text-align: center; margin-top: 3rem;">
        <a href="{{ collections[section.settings.collection].url }}" class="featured-products__view-all-btn" style="display: inline-block; padding: 12px 40px; background-color: #000; color: #fff; text-decoration: none; border-radius: 50px; font-weight: 500; letter-spacing: 1px; font-size: 0.9rem; transition: transform 0.3s ease, background-color 0.3s ease;">View all</a>
      </div>
    {%- endif -%}

  </div>

  {%- if section.settings.video != blank or section.settings.video_url != blank -%}
    <div class="featured-products__video-wrapper" style="margin-top: 4rem; width: 100vw; max-width: 100vw; margin-left: calc(50% - 50vw); aspect-ratio: 16 / 9; overflow: hidden; background-color: #000; display: block;">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, style: 'width: 100%; height: 100%; object-fit: cover; display: block;' }}
      {%- else -%}
        <video src="{{ section.settings.video_url }}" autoplay loop muted playsinline style="width: 100%; height: 100%; object-fit: cover; display: block;"></video>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{%- style -%}
  #FeaturedProducts-{{ section.id }} {
    padding: 5rem 0;
    background-color: var(--color-background);
  }

  .featured-products__header {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 4rem;
    padding-bottom: 1.5rem;
  }

  .featured-products__title {
    margin: 0;
  }

  .featured-products__view-all {
    color: var(--color-primary-accent, #000000);
    text-decoration: none;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .featured-products__view-all:hover {
    color: #fff;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media screen and (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 2.5rem;
    }
  }

  @media screen and (max-width: 768px) {
    #FeaturedProducts-{{ section.id }} {
      padding: 2.5rem 0;
    }
    .featured-products__header {
      margin-bottom: 2.5rem;
      padding-bottom: 0.5rem;
    }
    .featured-products__video-wrapper {
      margin-top: 2.5rem !important;
    }
  }
{%- endstyle -%}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // GSAP text animation for title if available
    setTimeout(() => {
      if (typeof window.animateTextReveal === 'function') {
        window.animateTextReveal('#FeaturedProducts-{{ section.id }} [data-animate-text]');
      }
    }, 200);
  });
</script>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Lead The Trend Dont Follow it"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Trendy Tees"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 4,
      "label": "Maximum products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Enable \"View all\" button if collection has more products than shown"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Section Video (16:9)"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Or Video URL (MP4)"
    }
  ],
  "blocks": [
    {
      "type": "custom_product",
      "name": "Custom Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Name",
          "default": "Custom T-Shirt"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$29.99"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Product Link"
        }
      ]
    },
    {
      "type": "shopify_product",
      "name": "Select Shopify Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "blocks": [
        { "type": "custom_product" },
        { "type": "custom_product" },
        { "type": "custom_product" },
        { "type": "custom_product" }
      ]
    }
  ]
}
{% endschema %}
