{% comment %}
  This section is used in the collection template to render collection page
  listing all products within a collection.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<section class="collection-page" id="CollectionPage-{{ section.id }}">
  <div class="page-width">
    <div class="collection-page__header">
      <h1 class="collection-page__title">{% if collection.handle == 'all' %}ALL PRODUCTS{% else %}{{ collection.title }}{% endif %}</h1>
      {%- if collection.description != blank -%}
        <div class="collection-page__description">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {% paginate collection.products by section.settings.products_per_page %}
        {%- if collection.products_count > 0 -%}
          {%- for product in collection.products -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        {%- else -%}
          <div style="grid-column: 1 / -1; text-align: center; padding: 4rem 0;">
            <p>No products found in this collection.</p>
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          <div class="collection-page__pagination" style="grid-column: 1 / -1; margin-top: 3rem;">
            {{ paginate | default_pagination: next: 'Next &raquo;', previous: '&laquo; Previous' }}
          </div>
        {%- endif -%}
      {% endpaginate %}
    </div>
  </div>
</section>

{%- style -%}
  #CollectionPage-{{ section.id }} {
    padding: 5rem 0;
    background-color: var(--color-background, #ffffff);
  }

  .collection-page__header {
    text-align: center;
    margin-bottom: 4rem;
    padding-bottom: 1.5rem;
  }

  .collection-page__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    letter-spacing: 2px;
    margin: 0;
    line-height: 1.1;
  }

  .collection-page__description {
    font-size: 1.1rem;
    color: #666;
    margin-top: 1rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media screen and (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 2.5rem;
    }
  }

  /* Pagination styles */
  .collection-page__pagination {
    text-align: center;
    font-weight: 500;
  }
  .collection-page__pagination span {
    display: inline-block;
    padding: 8px 16px;
    margin: 0 4px;
    background: #f4f4f4;
    border-radius: 4px;
    text-decoration: none;
    color: #000;
    transition: background 0.3s;
  }
  .collection-page__pagination span.current {
    background: #000;
    color: #fff;
  }
  .collection-page__pagination a {
    display: inline-block;
    padding: 8px 16px;
    margin: 0 4px;
    background: #f4f4f4;
    border-radius: 4px;
    text-decoration: none;
    color: #000;
    transition: background 0.3s;
  }
  .collection-page__pagination a:hover {
    background: #e0e0e0;
  }

  @media screen and (max-width: 768px) {
    #CollectionPage-{{ section.id }} {
      padding: 3rem 0;
    }
    .collection-page__header {
      margin-bottom: 2.5rem;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Collection Template",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    }
  ]
}
{% endschema %}
