<section class="category-slider-section" id="CategorySlider-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="category-slider__title" data-animate-text>{{ section.settings.title }}</h2>
    {%- endif -%}
  </div>
    
  <div class="category-slider__marquee-container">
    <div class="category-slider__marquee">
        <!-- Original Track -->
        <div class="category-slider__track">
          {%- for block in section.blocks -%}
            {%- assign collection = collections[block.settings.collection] -%}
            <a href="{{ collection.url | default: '#' }}" class="category-slider__item" {{ block.shopify_attributes }}>
              <div class="category-slider__image-wrapper">
                <div class="category-slider__image-inner">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'category-slider__image' }}
                  {%- elsif collection.image != blank -%}
                    {{ collection.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'category-slider__image' }}
                  {%- else -%}
                    <div class="category-slider__placeholder">
                      {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
              </div>
              <h3 class="category-slider__item-title">
                {{ block.settings.title | default: collection.title | default: 'Category Name' }}
              </h3>
            </a>
          {%- endfor -%}
        </div>
        
        <!-- Duplicated Track for Infinite Loop -->
        <div class="category-slider__track" aria-hidden="true">
          {%- for block in section.blocks -%}
            {%- assign collection = collections[block.settings.collection] -%}
            <a href="{{ collection.url | default: '#' }}" class="category-slider__item">
              <div class="category-slider__image-wrapper">
                <div class="category-slider__image-inner">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'category-slider__image' }}
                  {%- elsif collection.image != blank -%}
                    {{ collection.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'category-slider__image' }}
                  {%- else -%}
                    <div class="category-slider__placeholder">
                      {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
              </div>
              <h3 class="category-slider__item-title">
                {{ block.settings.title | default: collection.title | default: 'Category Name' }}
              </h3>
            </a>
          {%- endfor -%}
        </div>
      </div>
    </div>
</section>

{%- style -%}
  #CategorySlider-{{ section.id }} {
    padding: 6rem 0;
    background-color: var(--color-background);
    overflow: hidden;
  }

  .category-slider__title {
    text-align: center;
    font-size: clamp(2rem, 5vw, 3.5rem);
    text-transform: uppercase;
    font-style: italic;
    font-weight: 900;
    margin-bottom: 4rem;
    letter-spacing: 2px;
  }

  .category-slider__marquee-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: 2rem 0;
  }

  .category-slider__marquee {
    display: flex;
    width: max-content;
    animation: marquee-scroll 25s linear infinite;
  }

  .category-slider__marquee:hover {
    animation-play-state: paused;
  }

  .category-slider__track {
    display: flex;
    gap: 4rem;
    padding-right: 4rem; /* Space before duplicate starts */
  }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .category-slider__item {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    perspective: 1200px; /* For 3D effect */
  }

  .category-slider__image-wrapper {
    width: clamp(160px, 25vw, 240px);
    height: clamp(160px, 25vw, 240px);
    border-radius: 50%;
    padding: 10px; /* Border gap */
    background: linear-gradient(135deg, var(--color-primary-accent, #ffcc00), transparent);
    border: 2px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 15px 35px rgba(0,0,0,0.4), inset 0 0 20px rgba(255,255,255,0.05);
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.6s ease;
    transform-style: preserve-3d;
  }

  .category-slider__image-inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background-color: #000;
    position: relative;
    transform-style: preserve-3d;
  }

  .category-slider__image,
  .category-slider__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .category-slider__placeholder svg {
    fill: #444;
    background-color: #111;
  }

  /* 3D Hover Effects */
  .category-slider__item:hover .category-slider__image-wrapper {
    transform: rotateY(20deg) rotateX(15deg) scale(1.08) translateZ(30px);
    box-shadow: -20px 30px 50px rgba(0,0,0,0.6), inset 0 0 15px var(--color-primary-accent);
    border-color: var(--color-primary-accent);
  }

  .category-slider__item:hover .category-slider__image {
    transform: scale(1.15) translateZ(20px);
  }

  .category-slider__item-title {
    font-size: 1.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .category-slider__item:hover .category-slider__item-title {
    color: var(--color-primary-accent);
    transform: translateY(5px);
  }

  @media screen and (max-width: 768px) {
    .category-slider__track {
      gap: 2rem;
      padding-right: 2rem;
    }
    .category-slider__image-wrapper {
      width: 140px;
      height: 140px;
      padding: 6px;
    }
    .category-slider__item-title {
      font-size: 1rem;
    }
  }
{%- endstyle -%}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // GSAP text animation for title if available
    setTimeout(() => {
      if (typeof window.animateTextReveal === 'function') {
        window.animateTextReveal('#CategorySlider-{{ section.id }} [data-animate-text]');
      }
    }, 200);
  });
</script>

{% schema %}
{
  "name": "Category Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image",
          "info": "Overrides collection image if provided."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Overrides collection title if provided."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Slider",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
