<section class="category-slider-section" id="CategorySlider-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="category-slider__title" data-animate-text>{{ section.settings.title }}</h2>
    {%- endif -%}
    
    <div class="category-slider__container">
      <div class="category-slider__track" id="SliderTrack-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- assign collection = collections[block.settings.collection] -%}
          <a href="{{ collection.url | default: '#' }}" class="category-slider__item" {{ block.shopify_attributes }}>
            <div class="category-slider__image-wrapper">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'category-slider__image' }}
              {%- elsif collection.image != blank -%}
                {{ collection.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'category-slider__image' }}
              {%- else -%}
                <div class="category-slider__placeholder">
                  {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
            <h3 class="category-slider__item-title">
              {{ block.settings.title | default: collection.title | default: 'Category Name' }}
            </h3>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{%- style -%}
  #CategorySlider-{{ section.id }} {
    padding: 5rem 0;
    background-color: var(--color-background);
    overflow: hidden;
  }

  .category-slider__title {
    text-align: center;
    font-size: clamp(2rem, 5vw, 3.5rem);
    text-transform: uppercase;
    font-style: italic;
    font-weight: 900;
    margin-bottom: 3rem;
  }

  .category-slider__container {
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    cursor: grab;
  }

  .category-slider__container:active {
    cursor: grabbing;
  }

  .category-slider__track {
    display: flex;
    gap: 2rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 0 calc(50vw - 50% + var(--page-margin, 2rem));
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  .category-slider__track::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .category-slider__item {
    flex: 0 0 75vw;
    scroll-snap-align: center;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.3s ease;
  }

  @media screen and (min-width: 768px) {
    .category-slider__item {
      flex: 0 0 calc(33.333% - 1.33rem);
      scroll-snap-align: start;
    }
  }

  @media screen and (min-width: 1024px) {
    .category-slider__item {
      flex: 0 0 calc(25% - 1.5rem);
    }
  }

  .category-slider__item:hover {
    transform: translateY(-10px);
  }

  .category-slider__image-wrapper {
    position: relative;
    width: 100%;
    padding-top: 120%; /* Portrait aspect ratio */
    border-radius: 8px;
    overflow: hidden;
    background-color: #111;
    margin-bottom: 1.5rem;
  }

  .category-slider__image,
  .category-slider__placeholder svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .category-slider__placeholder svg {
    fill: #333;
    background-color: #222;
  }

  .category-slider__item:hover .category-slider__image {
    transform: scale(1.05);
  }

  .category-slider__item-title {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-align: center;
  }
{%- endstyle -%}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('SliderTrack-{{ section.id }}');
    if (!track) return;

    let isDown = false;
    let startX;
    let scrollLeft;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.style.scrollSnapType = 'none'; // Disable snap while dragging
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    track.addEventListener('mouseleave', () => {
      isDown = false;
      track.style.scrollSnapType = 'x mandatory';
    });

    track.addEventListener('mouseup', () => {
      isDown = false;
      track.style.scrollSnapType = 'x mandatory';
    });

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 2; // Scroll speed multiplier
      track.scrollLeft = scrollLeft - walk;
    });

    // GSAP text animation for title if available
    setTimeout(() => {
      if (typeof window.animateTextReveal === 'function') {
        window.animateTextReveal('#CategorySlider-{{ section.id }} [data-animate-text]');
      }
    }, 200);
  });
</script>

{% schema %}
{
  "name": "Category Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image",
          "info": "Overrides collection image if provided."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Overrides collection title if provided."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Slider",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
