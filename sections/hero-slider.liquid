{%- style -%}
  .hero-slider-section {
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    background: #000;
  }

  .hero-slider {
    width: 100%;
    height: 100vh;
    min-height: 600px;
  }

  .hero-slider .swiper-slide {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-slider__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-slider__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.3); /* Default overlay */
    z-index: 2;
  }

  .hero-slider__content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #fff;
    padding: 0 2rem;
    max-width: 800px;
  }

  .hero-slider__subheading {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  .hero-slider__heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 2.5rem;
  }

  .hero-slider__button {
    display: inline-block;
    padding: 1rem 2.5rem;
    border: 2px solid #fff;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    background: transparent;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .hero-slider__button:hover {
    background: #fff;
    color: #000;
  }

  /* Swiper Pagination */
  .hero-slider .swiper-pagination {
    bottom: 30px !important;
  }

  .hero-slider .swiper-pagination-bullet {
    width: 12px;
    height: 12px;
    background: #fff;
    opacity: 0.5;
    margin: 0 6px !important;
    transition: opacity 0.3s ease;
  }

  .hero-slider .swiper-pagination-bullet-active {
    opacity: 1;
  }

  @media screen and (max-width: 768px) {
    .hero-slider {
      height: 80vh;
      min-height: 500px;
    }
    .hero-slider__subheading {
      font-size: 0.8rem;
      letter-spacing: 2px;
    }
    .hero-slider__heading {
      font-size: clamp(2.5rem, 10vw, 3.5rem);
    }
  }
{%- endstyle -%}

<section class="hero-slider-section" id="HeroSlider-{{ section.id }}">
  <div class="swiper hero-slider">
    <div class="swiper-wrapper">
      {%- for block in section.blocks -%}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'hero-slider__image' }}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg hero-slider__image' }}
          {%- endif -%}
          
          <div class="hero-slider__overlay" style="background: rgba(0,0,0, {{ block.settings.overlay_opacity | divided_by: 100.0 }});"></div>
          
          <div class="hero-slider__content">
            {%- if block.settings.subheading != blank -%}
              <p class="hero-slider__subheading">{{ block.settings.subheading }}</p>
            {%- endif -%}
            
            {%- if block.settings.heading != blank -%}
              <h2 class="hero-slider__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link | default: '#' }}" class="hero-slider__button">
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
    <div class="swiper-pagination"></div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Swiper !== 'undefined') {
      new Swiper('#HeroSlider-{{ section.id }} .hero-slider', {
        loop: true,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false,
        },
        effect: 'fade',
        fadeEffect: {
          crossFade: true
        },
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
      });
    }
  });
</script>

{% schema %}
{
  "name": "Hero Slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 30
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "LUXURY STREETWEAR!"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feel The Luxury Thread"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
