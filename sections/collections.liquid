{% comment %}
  This section is used in the list-collections template to render a list of
  collections.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<section class="list-collections-page" id="ListCollections-{{ section.id }}">
  <div class="page-width">
    <div class="list-collections-page__header">
      <h1 class="list-collections-page__title">{{ 'collections.title' | t | default: 'ALL COLLECTIONS' }}</h1>
    </div>

    <div class="product-grid">
      {%- for collection in collections -%}
        {%- if collection.handle != 'frontpage' -%}
          <a class="collection-card-item" href="{{ collection.url }}">
            <div class="collection-card-item__image-wrapper">
              {%- if collection.featured_image -%}
                {{ collection.featured_image | image_url: width: 600 | image_tag: class: 'collection-card-item__image', loading: 'lazy' }}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg collection-card-item__image' }}
              {%- endif -%}
              <div class="collection-card-item__overlay"></div>
            </div>
      
            <div class="collection-card-item__info">
              <h3 class="collection-card-item__title">{{ collection.title }}</h3>
              {%- if collection.description != blank -%}
                <p class="collection-card-item__desc">{{ collection.description | strip_html | truncatewords: 15 }}</p>
              {%- endif -%}
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- style -%}
  #ListCollections-{{ section.id }} {
    padding: 5rem 0;
    background-color: var(--color-background, #ffffff);
  }

  .list-collections-page__header {
    text-align: center;
    margin-bottom: 4rem;
    padding-bottom: 1.5rem;
  }

  .list-collections-page__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    letter-spacing: 2px;
    margin: 0;
    line-height: 1.1;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media screen and (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 2.5rem;
    }
  }

  .collection-card-item {
    text-decoration: none;
    color: inherit;
    display: block;
    position: relative;
    group: collection;
  }

  .collection-card-item__image-wrapper {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    background-color: #f4f4f4;
    aspect-ratio: 4 / 5;
  }

  .collection-card-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .collection-card-item:hover .collection-card-item__image {
    transform: scale(1.05);
  }

  .collection-card-item__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .collection-card-item:hover .collection-card-item__overlay {
    opacity: 1;
  }

  .collection-card-item__info {
    margin-top: 1rem;
    text-align: center;
  }

  .collection-card-item__title {
    font-size: 1.2rem;
    font-weight: 800;
    text-transform: uppercase;
    margin: 0 0 0.5rem 0;
    letter-spacing: 1px;
    transition: color 0.3s ease;
  }

  .collection-card-item:hover .collection-card-item__title {
    color: #666;
  }

  .collection-card-item__desc {
    font-size: 0.9rem;
    color: #888;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    #ListCollections-{{ section.id }} {
      padding: 3rem 0;
    }
    .list-collections-page__header {
      margin-bottom: 2.5rem;
    }
    .collection-card-item__title {
      font-size: 1rem;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Collections Grid",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Number of columns on desktop"
    }
  ]
}
{% endschema %}
