{%- style -%}
  .collection-banners {
    padding: 5rem 0;
    background-color: #ffffff;
  }

  .collection-banners__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .collection-banners__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #000;
    margin: 0;
  }

  .collection-banners__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 0 1rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  @media screen and (min-width: 768px) {
    .collection-banners__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      padding: 0 2rem;
    }
  }

  .collection-card {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    text-decoration: none;
    background-color: #f5f5f5;
  }

  .collection-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .collection-card:hover .collection-card__image {
    transform: scale(1.05);
  }

  .collection-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 50%);
    z-index: 1;
  }

  .collection-card__info {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 2rem;
    z-index: 2;
    text-align: center;
  }

  .collection-card__title {
    color: #fff;
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }
  
  .collection-card__subtitle {
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    opacity: 0.9;
  }
{%- endstyle -%}

<section class="collection-banners" id="CollectionBanners-{{ section.id }}">
  <div class="collection-banners__header">
    <h2 class="collection-banners__title">{{ section.settings.title }}</h2>
  </div>

  <div class="collection-banners__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.collection.url | default: '#' }}" class="collection-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'collection-card__image' }}
        {%- elsif block.settings.collection.image != blank -%}
          {{ block.settings.collection.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'collection-card__image' }}
        {%- else -%}
          {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg collection-card__image' }}
        {%- endif -%}
        
        <div class="collection-card__overlay"></div>
        <div class="collection-card__info">
          <h3 class="collection-card__title">{{ block.settings.title | default: block.settings.collection.title | default: 'Collection' }}</h3>
          {%- if block.settings.subtitle != blank -%}
            <p class="collection-card__subtitle">{{ block.settings.subtitle }}</p>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Banners",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (Optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title (Optional)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Banners",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
