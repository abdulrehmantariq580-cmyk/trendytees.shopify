{%- style -%}
  .instagram-section {
    padding: 5rem 0;
    background-color: #ffffff;
    overflow: hidden;
  }

  .instagram__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .instagram__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #000;
    margin: 0;
  }

  .instagram-container {
    position: relative;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .instagram-container .swiper {
    width: 100%;
    padding-bottom: 1rem;
  }

  .instagram-card {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    overflow: hidden;
    background-color: #eee;
  }

  .instagram-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .instagram-card:hover .instagram-card__image {
    transform: scale(1.05);
  }

  /* Slider Navigation */
  .instagram-button-next,
  .instagram-button-prev {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    cursor: pointer;
    z-index: 10;
    color: #000;
    transition: background 0.3s, color 0.3s;
  }

  .instagram-button-next:hover,
  .instagram-button-prev:hover {
    background: #000;
    color: #fff;
  }

  .instagram-button-prev {
    left: 10px;
  }

  .instagram-button-next {
    right: 10px;
  }

  .instagram-button-next svg,
  .instagram-button-prev svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  @media screen and (max-width: 768px) {
    .instagram-container {
      padding: 0 1rem;
    }
    .instagram-button-next,
    .instagram-button-prev {
      display: none;
    }
  }

  .instagram__bottom {
    text-align: center;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .instagram-pagination {
    display: flex;
    justify-content: center;
    gap: 8px;
    align-items: center;
    position: relative !important;
    bottom: 0 !important;
  }

  .instagram-pagination .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    background: #ccc;
    opacity: 1;
    margin: 0 !important;
    transition: all 0.3s ease;
  }

  .instagram-pagination .swiper-pagination-bullet-active {
    width: 24px;
    background: #000;
    border-radius: 4px;
  }

  .instagram__button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #000;
    color: #fff;
    padding: 12px 32px;
    border-radius: 30px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    transition: background 0.3s;
  }

  .instagram__button:hover {
    background: #333;
  }

  .instagram__button svg {
    width: 20px;
    height: 20px;
    fill: #fff;
  }
{%- endstyle -%}

<section class="instagram-section" id="InstagramFeed-{{ section.id }}">
  <div class="instagram__header">
    <h2 class="instagram__title">{{ section.settings.title }}</h2>
  </div>

  <div class="instagram-container">
    <div class="swiper instagram-slider-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link | default: '#' }}" target="_blank" class="instagram-card">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'instagram-card__image' }}
              {%- else -%}
                {{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg instagram-card__image' }}
              {%- endif -%}
            </a>
          </div>
        {%- endfor -%}
      </div>
    </div>
    
    <div class="instagram-button-prev instagram-prev-{{ section.id }}">
      <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
    </div>
    <div class="instagram-button-next instagram-next-{{ section.id }}">
      <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
    </div>
  </div>

  <div class="instagram__bottom">
    <div class="swiper-pagination instagram-pagination instagram-pagination-{{ section.id }}"></div>
    
    <a href="{{ section.settings.instagram_link | default: '#' }}" target="_blank" class="instagram__button">
      <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      Instagram
    </a>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Swiper !== 'undefined') {
      new Swiper('.instagram-slider-{{ section.id }}', {
        slidesPerView: 1.5,
        spaceBetween: 16,
        centeredSlides: true,
        loop: true,
        navigation: {
          nextEl: '.instagram-next-{{ section.id }}',
          prevEl: '.instagram-prev-{{ section.id }}',
        },
        pagination: {
          el: '.instagram-pagination-{{ section.id }}',
          clickable: true,
        },
        breakpoints: {
          640: {
            slidesPerView: 2.5,
            spaceBetween: 20,
            centeredSlides: false,
          },
          1024: {
            slidesPerView: 4,
            spaceBetween: 24,
            centeredSlides: false,
          },
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Instagram Feed",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Instagram"
    },
    {
      "type": "url",
      "id": "instagram_link",
      "label": "Instagram Profile Link"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Instagram Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram Post Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
