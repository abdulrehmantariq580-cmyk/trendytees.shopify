<section class="about-us-section" id="AboutUs-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <div class="about-us__banner">
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'about-us__banner-img' }}
    </div>
  {%- endif -%}

  <div class="about-us__container page-width">
    <h2 class="about-us__title">{{ section.settings.heading }}</h2>
    <div class="about-us__text">
      {{ section.settings.text }}
    </div>
  </div>
</section>

{%- style -%}
  #AboutUs-{{ section.id }} {
    background-color: transparent;
    padding-bottom: 6rem;
  }

  .about-us__banner {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-bottom: 4rem;
  }

  .about-us__banner-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .about-us__container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .about-us__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #000;
    margin-bottom: 2rem;
    line-height: 1.2;
  }

  .about-us__text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #333;
    font-weight: 500;
  }
  
  .about-us__text p {
    margin-bottom: 1.5rem;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "About Us (Karvaan Style)",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Full Width Banner Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More Than Just A Clothing Brand"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Trendy Tees is more than just a clothing brand—it's a movement. Rooted in modern streetwear, each garment tells a powerful story of resilience, skill, and bold style.</p>"
    }
  ],
  "presets": [
    {
      "name": "About Us"
    }
  ]
}
{% endschema %}
