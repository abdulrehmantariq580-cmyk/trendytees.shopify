<section class="about-us-section" id="AboutUs-{{ section.id }}">
  <div class="about-us__container page-width">
    
    <div class="about-us__content">
      <h2 class="about-us__title">{{ section.settings.heading }}</h2>
      <div class="about-us__text">
        {{ section.settings.text }}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="about-us__button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="about-us__image-wrapper">
      <div class="about-us__image-inner">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'about-us__image' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg about-us__image' }}
        {%- endif -%}
      </div>
      <!-- Decorative element -->
      <div class="about-us__decorative-box"></div>
    </div>

  </div>
</section>

{%- style -%}
  #AboutUs-{{ section.id }} {
    padding: 8rem 0;
    background-color: #050505; /* Deep premium black */
    color: #ffffff;
    overflow: hidden;
    position: relative;
  }

  .about-us__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-us__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.1;
    margin-bottom: 2rem;
    letter-spacing: -1px;
    background: linear-gradient(90deg, #ffffff, #888888);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .about-us__text {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #cccccc;
    margin-bottom: 3rem;
    max-width: 90%;
  }

  .about-us__button {
    display: inline-block;
    padding: 14px 45px;
    background-color: #ffffff;
    color: #000000;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.95rem;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .about-us__button:hover {
    transform: translateY(-3px);
    background-color: #e0e0e0;
  }

  .about-us__image-wrapper {
    position: relative;
    padding-right: 2rem;
    padding-bottom: 2rem;
  }

  .about-us__image-inner {
    position: relative;
    z-index: 2;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    transition: transform 0.5s ease;
  }

  .about-us__image-inner:hover {
    transform: scale(1.02);
  }

  .about-us__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-us__decorative-box {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 80%;
    height: 80%;
    border: 2px solid rgba(255, 255, 255, 0.1);
    z-index: 1;
    border-radius: 12px;
    transform: translate(20px, 20px);
  }

  @media screen and (max-width: 990px) {
    #AboutUs-{{ section.id }} {
      padding: 5rem 0;
    }
    
    .about-us__container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .about-us__text {
      max-width: 100%;
    }

    .about-us__image-wrapper {
      padding-right: 1rem;
      padding-bottom: 1rem;
    }
    
    .about-us__decorative-box {
      transform: translate(10px, 10px);
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "About Us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Born in the Streets."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>We don't follow trends, we create them. Trendy Tees represents the bold, the unapologetic, and the visionaries. Every piece is crafted for maximum impact and ultimate comfort. Step into the new era of streetwear.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Discover More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "About Us"
    }
  ]
}
{% endschema %}
