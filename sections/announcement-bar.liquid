<div class="announcement-bar full-width" role="region" aria-label="Announcement" style="background-color: #000; color: #fff; padding: 10px 0; text-align: center; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;">
  <span class="announcement-bar__message">{{ section.settings.text }}</span>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "default": "PREMIUM T-SHIRTS • FREE SHIPPING ON ORDERS OVER $50 • NEW COLLECTION OUT NOW",
      "label": "Announcement Text"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
