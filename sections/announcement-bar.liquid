<style>
  .announcement-bar-wrapper {
    background-color: #000; color: #fff; padding: 10px 0; font-size: 0.8rem; letter-spacing: 1px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
  }
  @media screen and (max-width: 768px) {
    .announcement-bar-wrapper {
      grid-template-columns: 1fr;
      padding: 10px 0;
    }
    .announcement-bar__socials, .announcement-bar__empty {
      display: none !important;
    }
    .announcement-bar__message {
      font-size: 0.65rem;
    }
    .announcement-bar__content {
      gap: 0.5rem !important;
      width: 100%;
      justify-content: center;
    }
  }
</style>
<div class="announcement-bar full-width announcement-bar-wrapper" role="region" aria-label="Announcement">
  <div class="announcement-bar__socials" style="padding-left: 2rem; display: flex; gap: 15px;">
    <!-- Facebook Icon -->
    <a href="#" style="color: #fff; text-decoration: none;">
      <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
    </a>
    <!-- Instagram Icon -->
    <a href="#" style="color: #fff; text-decoration: none;">
      <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
    </a>
  </div>
  <div class="announcement-bar__content" style="text-align: center; display: flex; align-items: center; justify-content: center; width: 100%; max-width: 100%; margin: 0 auto; min-height: 24px;">
    <span class="announcement-prev" style="cursor: pointer; opacity: 0.7; padding: 0 15px; user-select: none;">&lt;</span>
    <div class="announcement-fade-wrapper" style="position: relative; display: flex; align-items: center; justify-content: center;">
      {% for block in section.blocks %}
        <span class="announcement-bar__message fade-slide" style="text-transform: uppercase; text-align: center; transition: opacity 0.5s ease-in-out; max-width: calc(100vw - 100px); {% if forloop.first %}opacity: 1; position: relative; z-index: 1; left: auto; transform: none; width: auto;{% else %}opacity: 0; position: absolute; z-index: 0; pointer-events: none; left: 50%; transform: translateX(-50%); width: max-content;{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      {% else %}
        <span class="announcement-bar__message fade-slide" style="text-transform: uppercase; text-align: center; opacity: 1; position: relative; max-width: calc(100vw - 100px); left: auto; transform: none; width: auto;">{{ section.settings.text }}</span>
      {% endfor %}
    </div>
    <span class="announcement-next" style="cursor: pointer; opacity: 0.7; padding: 0 15px; user-select: none;">&gt;</span>
  </div>
  <div class="announcement-bar__empty"></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const prevBtn = document.querySelector('.announcement-prev');
    const nextBtn = document.querySelector('.announcement-next');
    const slides = document.querySelectorAll('.fade-slide');
    
    if (slides.length <= 1) {
      if (prevBtn) prevBtn.style.display = 'none';
      if (nextBtn) nextBtn.style.display = 'none';
      return;
    }

    let currentIndex = 0;
    const slideCount = slides.length;
    let interval;

    function goToSlide(index) {
      slides[currentIndex].style.opacity = '0';
      slides[currentIndex].style.position = 'absolute';
      slides[currentIndex].style.zIndex = '0';
      slides[currentIndex].style.pointerEvents = 'none';
      slides[currentIndex].style.left = '50%';
      slides[currentIndex].style.transform = 'translateX(-50%)';
      slides[currentIndex].style.width = 'max-content';

      if (index < 0) index = slideCount - 1;
      if (index >= slideCount) index = 0;
      currentIndex = index;

      slides[currentIndex].style.opacity = '1';
      slides[currentIndex].style.position = 'relative';
      slides[currentIndex].style.zIndex = '1';
      slides[currentIndex].style.pointerEvents = 'auto';
      slides[currentIndex].style.left = 'auto';
      slides[currentIndex].style.transform = 'none';
      slides[currentIndex].style.width = 'auto';
    }

    function nextSlide() {
      goToSlide(currentIndex + 1);
    }

    function prevSlide() {
      goToSlide(currentIndex - 1);
    }

    function startAutoSlide() {
      interval = setInterval(nextSlide, 4000);
    }

    function stopAutoSlide() {
      clearInterval(interval);
    }

    if(nextBtn) {
      nextBtn.addEventListener('click', () => {
        stopAutoSlide();
        nextSlide();
        startAutoSlide();
      });
    }

    if(prevBtn) {
      prevBtn.addEventListener('click', () => {
        stopAutoSlide();
        prevSlide();
        startAutoSlide();
      });
    }

    const wrapper = document.querySelector('.announcement-bar__content');
    if(wrapper) {
      wrapper.addEventListener('mouseenter', stopAutoSlide);
      wrapper.addEventListener('mouseleave', startAutoSlide);
    }

    startAutoSlide();
  });
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "default": "PREMIUM T-SHIRTS • FREE SHIPPING ON ORDERS OVER $50 • NEW COLLECTION OUT NOW",
      "label": "Announcement Text"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "PREMIUM T-SHIRTS",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "announcement"
        },
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
