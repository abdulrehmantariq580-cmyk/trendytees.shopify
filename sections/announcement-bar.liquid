<style>
  .announcement-bar-wrapper {
    background-color: #000; color: #fff; padding: 10px 0; font-size: 0.8rem; letter-spacing: 1px; display: flex; justify-content: center; align-items: center; overflow: hidden;
  }
  .announcement-bar__content {
    display: flex; align-items: center; justify-content: center; width: 100%; max-width: 100%; padding: 0 10px; box-sizing: border-box;
  }
  .announcement-fade-wrapper {
    display: grid; align-items: center; justify-items: center;
  }
  .announcement-bar__message {
    grid-area: 1 / 1; text-transform: uppercase; text-align: center; white-space: nowrap; transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
  }
  .announcement-bar__socials, .announcement-bar__empty {
    display: none; /* Hide socials in slider to guarantee center alignment */
  }
  @media screen and (max-width: 768px) {
    .announcement-bar-wrapper {
      padding: 10px 0;
    }
    .announcement-bar__message {
      font-size: 12px !important;
      letter-spacing: 0.5px;
      white-space: normal; /* Allow wrapping */
      line-height: 1.3;
      display: -webkit-box;
      -webkit-line-clamp: 2; /* Maximum 2 lines */
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .announcement-bar__content {
      gap: 0.5rem;
    }
    .announcement-fade-wrapper {
      max-width: calc(100vw - 60px);
    }
  }
</style>
<div class="announcement-bar full-width announcement-bar-wrapper" role="region" aria-label="Announcement">
  <div class="announcement-bar__content">
    <span class="announcement-prev" style="cursor: pointer; opacity: 0.7; padding: 0 10px; user-select: none; flex-shrink: 0; font-weight: bold;">&lt;</span>
    <div class="announcement-fade-wrapper">
      {% for block in section.blocks %}
        <span class="announcement-bar__message fade-slide" style="{% if forloop.first %}opacity: 1; visibility: visible; pointer-events: auto;{% else %}opacity: 0; visibility: hidden; pointer-events: none;{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      {% else %}
        <span class="announcement-bar__message fade-slide" style="opacity: 1; visibility: visible;">{{ section.settings.text }}</span>
      {% endfor %}
    </div>
    <span class="announcement-next" style="cursor: pointer; opacity: 0.7; padding: 0 10px; user-select: none; flex-shrink: 0; font-weight: bold;">&gt;</span>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const prevBtn = document.querySelector('.announcement-prev');
    const nextBtn = document.querySelector('.announcement-next');
    const slides = document.querySelectorAll('.fade-slide');
    
    if (slides.length <= 1) {
      if (prevBtn) prevBtn.style.display = 'none';
      if (nextBtn) nextBtn.style.display = 'none';
      return;
    }

    let currentIndex = 0;
    const slideCount = slides.length;
    let interval;

    // Font size scaling removed - using CSS line-wrapping for mobile instead
    
    function goToSlide(index) {
      slides[currentIndex].style.opacity = '0';
      slides[currentIndex].style.visibility = 'hidden';
      slides[currentIndex].style.pointerEvents = 'none';

      if (index < 0) index = slideCount - 1;
      if (index >= slideCount) index = 0;
      currentIndex = index;

      slides[currentIndex].style.opacity = '1';
      slides[currentIndex].style.visibility = 'visible';
      slides[currentIndex].style.pointerEvents = 'auto';
    }

    function nextSlide() {
      goToSlide(currentIndex + 1);
    }

    function prevSlide() {
      goToSlide(currentIndex - 1);
    }

    function startAutoSlide() {
      interval = setInterval(nextSlide, 4000);
    }

    function stopAutoSlide() {
      clearInterval(interval);
    }

    if(nextBtn) {
      nextBtn.addEventListener('click', () => {
        stopAutoSlide();
        nextSlide();
        startAutoSlide();
      });
    }

    if(prevBtn) {
      prevBtn.addEventListener('click', () => {
        stopAutoSlide();
        prevSlide();
        startAutoSlide();
      });
    }

    const wrapper = document.querySelector('.announcement-bar__content');
    if(wrapper) {
      wrapper.addEventListener('mouseenter', stopAutoSlide);
      wrapper.addEventListener('mouseleave', startAutoSlide);
    }

    startAutoSlide();
  });
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "default": "PREMIUM T-SHIRTS • FREE SHIPPING ON ORDERS OVER $50 • NEW COLLECTION OUT NOW",
      "label": "Announcement Text"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "PREMIUM T-SHIRTS",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "announcement"
        },
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
