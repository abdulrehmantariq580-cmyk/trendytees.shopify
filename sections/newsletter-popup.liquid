{%- if section.settings.enable_popup -%}
  <div id="NewsletterPopup-{{ section.id }}" class="newsletter-popup" data-delay="{{ section.settings.delay }}" data-exit-intent="{{ section.settings.exit_intent }}" data-days-to-hide="{{ section.settings.days_to_hide }}">
    <div class="newsletter-popup__overlay"></div>
    <div class="newsletter-popup__content">
      <button class="newsletter-popup__close" aria-label="Close popup">
        <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
      </button>

      {%- if section.settings.image != blank -%}
        <div class="newsletter-popup__image-wrapper">
          {{ section.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'newsletter-popup__image' }}
        </div>
      {%- endif -%}

      <div class="newsletter-popup__form-wrapper {% if section.settings.image == blank %}newsletter-popup__form-wrapper--full{% endif %}">
        {%- if section.settings.title != blank -%}
          <h3 class="newsletter-popup__title">{{ section.settings.title }}</h3>
        {%- endif -%}
        
        {%- if section.settings.text != blank -%}
          <div class="newsletter-popup__text">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- form 'customer', class: 'newsletter-popup__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          <div class="newsletter-popup__input-group">
            <input type="email"
              name="contact[email]"
              class="newsletter-popup__input"
              value="{% if customer %}{{ customer.email }}{% endif %}"
              placeholder="Enter your email"
              aria-label="Email address"
              required>
            <button type="submit" class="newsletter-popup__submit btn" name="commit">
              Subscribe
            </button>
          </div>

          {%- if form.posted_successfully? -%}
            <p class="newsletter-popup__success">Thanks for subscribing!</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="newsletter-popup__error">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>

  {%- style -%}
    .newsletter-popup {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.4s ease, visibility 0.4s ease;
    }

    .newsletter-popup.is-visible {
      pointer-events: auto;
      opacity: 1;
      visibility: visible;
    }

    .newsletter-popup__overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(5px);
    }

    .newsletter-popup__content {
      position: relative;
      background: #111;
      width: 90%;
      max-width: 800px;
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: 0 25px 50px rgba(0,0,0,0.5);
      transform: translateY(50px) scale(0.95);
      transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid rgba(255,255,255,0.1);
    }

    .newsletter-popup.is-visible .newsletter-popup__content {
      transform: translateY(0) scale(1);
    }

    @media screen and (min-width: 768px) {
      .newsletter-popup__content {
        flex-direction: row;
        height: 450px;
      }
    }

    .newsletter-popup__close {
      position: absolute;
      top: 15px;
      right: 15px;
      background: rgba(0,0,0,0.5);
      color: #fff;
      border: none;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 10;
      transition: background 0.3s ease, transform 0.3s ease;
    }

    .newsletter-popup__close:hover {
      background: #fff;
      color: #000;
      transform: rotate(90deg);
    }

    .newsletter-popup__image-wrapper {
      width: 100%;
      height: 200px;
      flex-shrink: 0;
    }

    @media screen and (min-width: 768px) {
      .newsletter-popup__image-wrapper {
        width: 50%;
        height: 100%;
      }
    }

    .newsletter-popup__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .newsletter-popup__form-wrapper {
      padding: 3rem 2rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      width: 100%;
    }

    @media screen and (min-width: 768px) {
      .newsletter-popup__form-wrapper {
        width: 50%;
        padding: 3rem;
      }
      .newsletter-popup__form-wrapper--full {
        width: 100%;
        align-items: center;
        text-align: center;
      }
    }

    .newsletter-popup__title {
      font-size: 2rem;
      margin-bottom: 1rem;
      text-transform: uppercase;
      font-weight: 900;
      font-style: italic;
    }

    .newsletter-popup__text {
      font-size: 1rem;
      color: #ccc;
      margin-bottom: 2rem;
      line-height: 1.5;
    }

    .newsletter-popup__input-group {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    @media screen and (min-width: 768px) {
      .newsletter-popup__form-wrapper--full .newsletter-popup__input-group {
        flex-direction: row;
        width: 100%;
        max-width: 500px;
      }
    }

    .newsletter-popup__input {
      padding: 12px 15px;
      background: #222;
      border: 1px solid #444;
      color: #fff;
      border-radius: 4px;
      font-size: 1rem;
      width: 100%;
    }

    .newsletter-popup__input:focus {
      outline: none;
      border-color: var(--color-primary-accent, #ffcc00);
    }

    .newsletter-popup__submit {
      padding: 12px 25px;
      background: var(--color-primary-accent, #ffcc00);
      color: #000;
      font-weight: bold;
      text-transform: uppercase;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      transition: opacity 0.3s ease;
      white-space: nowrap;
    }

    .newsletter-popup__submit:hover {
      opacity: 0.9;
    }

    .newsletter-popup__success {
      color: #4caf50;
      margin-top: 1rem;
      font-weight: bold;
    }

    .newsletter-popup__error {
      color: #f44336;
      margin-top: 1rem;
    }
  {%- endstyle -%}

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const popup = document.getElementById('NewsletterPopup-{{ section.id }}');
      if (!popup) return;

      const overlay = popup.querySelector('.newsletter-popup__overlay');
      const closeBtn = popup.querySelector('.newsletter-popup__close');
      
      const delay = parseInt(popup.dataset.delay) * 1000;
      const exitIntent = popup.dataset.exitIntent === 'true';
      const daysToHide = parseInt(popup.dataset.daysToHide);
      const cookieName = 'trendy_newsletter_dismissed';

      // Check if popup should be shown
      const hasDismissed = localStorage.getItem(cookieName);
      if (hasDismissed) {
        const dismissTime = parseInt(hasDismissed);
        const now = new Date().getTime();
        const daysPassed = (now - dismissTime) / (1000 * 60 * 60 * 24);
        
        if (daysPassed < daysToHide) {
          return; // Still hiding
        } else {
          localStorage.removeItem(cookieName); // Expired, show again
        }
      }

      // Automatically shown if form was successfully submitted (Shopify reloads page)
      const isSuccess = popup.querySelector('.newsletter-popup__success');
      const isError = popup.querySelector('.newsletter-popup__error');
      if (isSuccess || isError) {
        showPopup();
        if (isSuccess) setDismissedCookie(365); // Hide for a year if subscribed
      } else {
        // Show after delay
        if (delay > 0) {
          setTimeout(showPopup, delay);
        }

        // Show on exit intent
        if (exitIntent) {
          let exitTriggered = false;
          document.addEventListener('mouseleave', (e) => {
            if (e.clientY < 0 && !exitTriggered) {
              exitTriggered = true;
              showPopup();
            }
          });
        }
      }

      function showPopup() {
        if (!popup.classList.contains('is-visible')) {
          popup.classList.add('is-visible');
        }
      }

      function closePopup() {
        popup.classList.remove('is-visible');
        setDismissedCookie(daysToHide);
      }

      function setDismissedCookie(days) {
        localStorage.setItem(cookieName, new Date().getTime().toString());
      }

      closeBtn.addEventListener('click', closePopup);
      overlay.addEventListener('click', closePopup);
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Newsletter Popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_popup",
      "label": "Enable Popup",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Optional. If not set, popup will be text only."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Join the Drop"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Subscribe to get 10% off your first order and exclusive access to new releases.</p>"
    },
    {
      "type": "range",
      "id": "delay",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Delay Time",
      "default": 5,
      "info": "Show popup after X seconds (0 to disable time delay)"
    },
    {
      "type": "checkbox",
      "id": "exit_intent",
      "label": "Enable Exit Intent",
      "default": true,
      "info": "Shows popup when user attempts to leave the page (Desktop only)"
    },
    {
      "type": "range",
      "id": "days_to_hide",
      "min": 1,
      "max": 30,
      "step": 1,
      "label": "Days to hide after closing",
      "default": 7
    }
  ],
  "presets": [
    {
      "name": "Newsletter Popup"
    }
  ]
}
{% endschema %}
