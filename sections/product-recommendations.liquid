{%- assign limit = section.settings.products_to_show | default: 4 -%}
{%- assign current_product_id = product.id -%}

<div class="product-recommendations">
  <div class="page-width" style="padding-top: 4rem; padding-bottom: 4rem; border-top: 1px solid #eee;">
    <h2 class="product-recommendations__heading" style="text-align: center; font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 700; text-transform: uppercase; margin-bottom: 3rem;">{{ section.settings.heading }}</h2>
    
    <div class="product-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
      {%- assign count = 0 -%}
      {%- assign current_time = "now" | date: "%s" | modulo: 10 -%}
      
      {% comment %} Output exactly 'limit' products from all products {% endcomment %}
      {%- for prod in collections.all.products offset: current_time -%}
        {%- if prod.id != current_product_id -%}
          <div class="random-product-card">
            {% render 'product-card', product: prod %}
          </div>
          {%- assign count = count | plus: 1 -%}
          {%- if count >= limit -%}
            {%- break -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      
      {% comment %} In case the offset caused us to get less than 'limit' products, fill the rest from the start {% endcomment %}
      {%- if count < limit -%}
        {%- for prod in collections.all.products -%}
          {%- if prod.id != current_product_id -%}
            <div class="random-product-card">
              {% render 'product-card', product: prod %}
            </div>
            {%- assign count = count | plus: 1 -%}
            {%- if count >= limit -%}
              {%- break -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  @media screen and (min-width: 768px) {
    .product-recommendations .product-grid {
      grid-template-columns: repeat(3, 1fr) !important;
      gap: 2rem !important;
    }
  }
  @media screen and (min-width: 1024px) {
    .product-recommendations .product-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop | default: 4 }}, 1fr) !important;
      gap: 2.5rem !important;
    }
  }
</style>

{% schema %}
{
  "name": "Product recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "You May Also Like",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    }
  ]
}
{% endschema %}
