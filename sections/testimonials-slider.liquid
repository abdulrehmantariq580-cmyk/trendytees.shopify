{%- style -%}
  .testimonials-section {
    padding: 6rem 0;
    background-color: #111; /* Dark background */
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden; /* For Swiper */
    color: #fff;
  }

  .testimonials-container {
    max-width: 1000px;
    width: 90%;
    margin: 0 auto;
    text-align: center;
  }

  .testimonials-tagline {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 2rem;
  }

  /* Swiper styles for testimonials */
  .testimonials-swiper {
    width: 100%;
    padding-bottom: 4rem; /* Space for pagination */
  }

  .testimonial-slide {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .testimonial-slide.swiper-slide-active {
    opacity: 1;
  }

  .testimonial-stars {
    color: #f5b301; /* Gold color */
    font-size: 1.2rem;
    margin-bottom: 2.5rem;
    letter-spacing: 0.1em;
  }

  .testimonial-text {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1.2rem, 3.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.6;
    color: #fff;
    max-width: 800px;
    margin: 0 auto 2.5rem auto;
  }

  .testimonial-author {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    color: #ccc;
  }

  /* Custom Pagination (Dots to pill) */
  .testimonials-pagination {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    gap: 8px;
    z-index: 10;
  }

  .testimonials-pagination .swiper-pagination-bullet {
    width: 6px;
    height: 6px;
    background: #555;
    opacity: 1;
    border-radius: 50%;
    transition: all 0.3s ease;
    margin: 0 !important;
  }

  .testimonials-pagination .swiper-pagination-bullet-active {
    width: 24px;
    background: #fff;
    border-radius: 4px;
  }

  @media screen and (max-width: 768px) {
    .testimonials-section {
      width: 100vw;
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      padding: 4rem 0;
    }
    .testimonial-text {
      font-size: 1.4rem;
    }
  }
{%- endstyle -%}

<!-- Swiper CSS & JS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<section class="testimonials-section" id="Testimonials-{{ section.id }}">
  <div class="testimonials-container">
    {%- if section.settings.tagline != blank -%}
      <div class="testimonials-tagline">{{ section.settings.tagline }}</div>
    {%- endif -%}

    <div class="swiper testimonials-swiper" id="TestimonialsSwiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide testimonial-slide" {{ block.shopify_attributes }}>
            <div class="testimonial-stars">
              {%- assign stars = block.settings.stars | plus: 0 -%}
              {%- for i in (1..5) -%}
                {%- if i <= stars -%}
                  ★
                {%- else -%}
                  ☆
                {%- endif -%}
              {%- endfor -%}
            </div>
            
            <div class="testimonial-text">
              "{{ block.settings.text }}"
            </div>
            
            <div class="testimonial-author">
              — {{ block.settings.author }}
            </div>
          </div>
        {%- endfor -%}
      </div>
      
      <!-- Custom Pagination -->
      <div class="swiper-pagination testimonials-pagination"></div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const initTestimonialsSwiper = () => {
      if (typeof Swiper !== 'undefined') {
        new Swiper('#TestimonialsSwiper-{{ section.id }}', {
          slidesPerView: 1,
          spaceBetween: 30,
          loop: true,
          autoplay: {
            delay: 5000,
            disableOnInteraction: false,
          },
          effect: 'fade',
          fadeEffect: {
            crossFade: true
          },
          pagination: {
            el: '.testimonials-pagination',
            clickable: true,
          },
        });
      } else {
        setTimeout(initTestimonialsSwiper, 100);
      }
    };
    initTestimonialsSwiper();
  });
</script>

{% schema %}
{
  "name": "Testimonials Slider",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "T E S T I M O N I A L S"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial Text",
          "default": "I received my order within a few days and was genuinely impressed by the quality. The fabric feels premium and the fit was exactly as expected."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Rayyan Saeed"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Slider",
      "blocks": [
        { "type": "testimonial", "settings": { "text": "I received my order within a few days and was genuinely impressed by the quality. The fabric feels premium and the fit was exactly as expected.", "author": "Rayyan Saeed", "stars": 5 } },
        { "type": "testimonial", "settings": { "text": "The drop shoulder tees are incredible. Fits perfectly and looks super stylish. Highly recommend Trendy Tees to everyone!", "author": "Ali Khan", "stars": 5 } },
        { "type": "testimonial", "settings": { "text": "Best customer service and amazing packaging. The clothes feel luxurious and comfortable.", "author": "Ahmed Raza", "stars": 5 } }
      ]
    }
  ]
}
{% endschema %}
