<section id="ShopTheLook-{{ section.id }}" class="shop-the-look page-width">
  {%- if section.settings.title != blank -%}
    <h2 class="shop-the-look__heading" data-animate-text>{{ section.settings.title }}</h2>
  {%- endif -%}

  <div class="shop-the-look__container">
    <div class="shop-the-look__image-wrapper">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1500 | image_tag: class: 'shop-the-look__image', loading: 'lazy' }}
      {%- else -%}
        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg shop-the-look__image' }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <div class="hotspot" style="top: {{ block.settings.top_position }}%; left: {{ block.settings.left_position }}%;" {{ block.shopify_attributes }}>
          <button class="hotspot__btn" aria-label="View product details">
            <span class="hotspot__dot"></span>
          </button>
          
          <div class="hotspot__popup">
            {%- if product != blank -%}
              <a href="{{ product.url }}" class="hotspot__popup-inner">
                <div class="hotspot__popup-img">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 200 | image_tag }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
                <div class="hotspot__popup-info">
                  <h4 class="hotspot__popup-title">{{ product.title }}</h4>
                  <p class="hotspot__popup-price">{{ product.price | money }}</p>
                  <span class="hotspot__popup-link">View Product</span>
                </div>
              </a>
            {%- else -%}
              <div class="hotspot__popup-inner">
                <div class="hotspot__popup-img">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
                <div class="hotspot__popup-info">
                  <h4 class="hotspot__popup-title">Example Product</h4>
                  <p class="hotspot__popup-price">$29.99</p>
                  <span class="hotspot__popup-link">Select Product</span>
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- style -%}
  #ShopTheLook-{{ section.id }} {
    padding: 6rem 0;
  }

  .shop-the-look__heading {
    text-align: center;
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    font-style: italic;
    font-weight: 900;
    margin-bottom: 3rem;
  }

  .shop-the-look__container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .shop-the-look__image-wrapper {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
  }

  .shop-the-look__image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Hotspot Styles */
  .hotspot {
    position: absolute;
    z-index: 10;
    transform: translate(-50%, -50%);
  }

  .hotspot__btn {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 0;
    transition: transform 0.3s ease;
  }

  .hotspot__btn:hover {
    transform: scale(1.1);
  }

  .hotspot__dot {
    width: 12px;
    height: 12px;
    background-color: #fff;
    border-radius: 50%;
    position: relative;
    box-shadow: 0 2px 5px rgba(0,0,0,0.3);
  }

  .hotspot__dot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    background-color: #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    animation: pulse 2s infinite cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes pulse {
    0% { transform: translate(-50%, -50%) scale(1); opacity: 0.8; }
    100% { transform: translate(-50%, -50%) scale(3.5); opacity: 0; }
  }

  /* Popup Styles */
  .hotspot__popup {
    position: absolute;
    top: calc(100% + 15px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    width: max-content;
    max-width: 280px;
    background: #000;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 10px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    z-index: 20;
    pointer-events: none;
  }

  .hotspot__popup::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: #000;
    border-left: 1px solid rgba(255,255,255,0.1);
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  /* When hotspot is active/hovered */
  .hotspot:hover .hotspot__popup,
  .hotspot.is-active .hotspot__popup {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  /* Adjust popup if too close to right edge */
  .hotspot[style*="left: 8"], .hotspot[style*="left: 9"] .hotspot__popup {
    left: auto;
    right: -20px;
    transform: translateX(0) translateY(10px);
  }
  .hotspot[style*="left: 8"]:hover .hotspot__popup, .hotspot[style*="left: 9"]:hover .hotspot__popup,
  .hotspot[style*="left: 8"].is-active .hotspot__popup, .hotspot[style*="left: 9"].is-active .hotspot__popup {
    transform: translateX(0) translateY(0);
  }
  .hotspot[style*="left: 8"] .hotspot__popup::before, .hotspot[style*="left: 9"] .hotspot__popup::before {
    left: auto;
    right: 25px;
    transform: translateX(0) rotate(45deg);
  }

  /* Adjust popup if too close to left edge */
  .hotspot[style*="left: 0"], .hotspot[style*="left: 1"], .hotspot[style*="left: 20"] .hotspot__popup {
    left: -20px;
    transform: translateX(0) translateY(10px);
  }
  .hotspot[style*="left: 0"]:hover .hotspot__popup, .hotspot[style*="left: 1"]:hover .hotspot__popup, .hotspot[style*="left: 20"]:hover .hotspot__popup,
  .hotspot[style*="left: 0"].is-active .hotspot__popup, .hotspot[style*="left: 1"].is-active .hotspot__popup, .hotspot[style*="left: 20"].is-active .hotspot__popup {
    transform: translateX(0) translateY(0);
  }
  .hotspot[style*="left: 0"] .hotspot__popup::before, .hotspot[style*="left: 1"] .hotspot__popup::before, .hotspot[style*="left: 20"] .hotspot__popup::before {
    left: 25px;
    transform: translateX(0) rotate(45deg);
  }

  /* Adjust popup if too close to bottom */
  .hotspot[style*="top: 8"], .hotspot[style*="top: 9"] .hotspot__popup {
    top: auto;
    bottom: calc(100% + 15px);
  }
  .hotspot[style*="top: 8"] .hotspot__popup::before, .hotspot[style*="top: 9"] .hotspot__popup::before {
    top: auto;
    bottom: -6px;
    border-left: none;
    border-top: none;
    border-right: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .hotspot__popup-inner {
    display: flex;
    gap: 15px;
    align-items: center;
    text-decoration: none;
    color: #fff;
  }

  .hotspot__popup-img {
    width: 70px;
    height: 90px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
    background: #222;
  }

  .hotspot__popup-img img, .hotspot__popup-img svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hotspot__popup-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hotspot__popup-title {
    font-size: 0.95rem;
    margin: 0 0 5px;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .hotspot__popup-price {
    font-size: 0.9rem;
    color: #ccc;
    margin: 0 0 8px;
  }

  .hotspot__popup-link {
    font-size: 0.8rem;
    color: var(--color-primary-accent, #ffcc00);
    text-transform: uppercase;
    font-weight: bold;
    letter-spacing: 1px;
    display: inline-block;
  }
{%- endstyle -%}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Reveal animation
    setTimeout(() => {
      if (typeof window.animateTextReveal === 'function') {
        window.animateTextReveal('#ShopTheLook-{{ section.id }} [data-animate-text]');
      }
    }, 200);
  });
</script>

{% schema %}
{
  "name": "Shop The Look",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop The Look"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "top_position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical Position",
          "default": 50
        },
        {
          "type": "range",
          "id": "left_position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal Position",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop The Look",
      "blocks": [
        {
          "type": "hotspot",
          "settings": {
            "top_position": 40,
            "left_position": 30
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "top_position": 60,
            "left_position": 70
          }
        }
      ]
    }
  ]
}
{% endschema %}
